<style>
  .jgz-values {
    background: var(--jgz-off-white);
    padding: 100px var(--jgz-px);
  }

  .jgz-values__inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 80px;
    align-items: start;
  }

  .jgz-values__left {}

  .jgz-values__kicker {
    font-family: var(--jgz-body);
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--jgz-gold);
    margin: 0 0 16px;
  }

  .jgz-values__heading {
    font-family: var(--jgz-heading);
    font-size: 56px;
    font-weight: 300;
    line-height: 1.05;
    color: var(--jgz-black);
    margin: 0;
  }

  .jgz-values__right {
    padding-top: 8px;
  }

  .jgz-values__item {
    padding: 28px 0;
    border-top: 1px solid rgba(10,10,10,0.1);
    display: grid;
    grid-template-columns: 40px 1fr;
    gap: 20px;
    align-items: start;
  }
  .jgz-values__item:last-child { border-bottom: 1px solid rgba(10,10,10,0.1); }

  .jgz-values__number {
    font-family: var(--jgz-body);
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.1em;
    color: var(--jgz-gold);
    padding-top: 2px;
  }

  .jgz-values__item-title {
    font-family: var(--jgz-heading);
    font-size: 22px;
    font-weight: 600;
    color: var(--jgz-black);
    margin: 0 0 6px;
  }

  .jgz-values__item-desc {
    font-family: var(--jgz-body);
    font-size: 13px;
    font-weight: 300;
    color: var(--jgz-black);
    opacity: 0.6;
    margin: 0;
    line-height: 1.6;
  }

  @media (max-width: 768px) {
    .jgz-values {
      padding: 60px var(--jgz-px-m);
    }
    .jgz-values__inner {
      grid-template-columns: 1fr;
      gap: 48px;
    }
    .jgz-values__heading { font-size: 40px; }
  }
</style>

<section class="jgz-values">
  <div class="jgz-values__inner">
    <div class="jgz-values__left">
      <p class="jgz-values__kicker">{{ section.settings.kicker }}</p>
      <h2 class="jgz-values__heading">{{ section.settings.heading }}</h2>
    </div>

    <div class="jgz-values__right">
      {%- for block in section.blocks -%}
        <div class="jgz-values__item" {{ block.shopify_attributes }}>
          <span class="jgz-values__number">0{{ forloop.index }}</span>
          <div>
            <h3 class="jgz-values__item-title">{{ block.settings.title }}</h3>
            <p class="jgz-values__item-desc">{{ block.settings.description }}</p>
          </div>
        </div>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "JIGERZ Brand Values",
  "settings": [
    { "type": "text", "id": "kicker", "label": "Kicker text", "default": "Why JIGERZ" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Built on Values That Matter" }
  ],
  "blocks": [
    {
      "type": "value",
      "name": "Value",
      "settings": [
        { "type": "text", "id": "title", "label": "Title", "default": "Premium Fabric" },
        { "type": "textarea", "id": "description", "label": "Description", "default": "100% ring-spun cotton sourced from premium mills. Every stitch is engineered for comfort." }
      ]
    }
  ],
  "presets": [
    {
      "name": "JIGERZ Brand Values",
      "blocks": [
        { "type": "value", "settings": { "title": "Premium Fabric", "description": "100% ring-spun cotton from premium mills. Breathable, durable, and built to last." } },
        { "type": "value", "settings": { "title": "Modern Fit", "description": "Smart silhouettes designed for the Pakistani physique. Not too slim, not too loose." } },
        { "type": "value", "settings": { "title": "Everyday Comfort", "description": "Engineered for all-day wear in Pakistan's climate. Light, airy, and sweat-resistant." } }
      ]
    }
  ]
}
{% endschema %}
