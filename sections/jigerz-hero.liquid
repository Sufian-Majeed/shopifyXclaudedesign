<style>
  .jgz-hero {
    position: relative;
    height: 92vh;
    min-height: 600px;
    background: #0a0a0a;
    overflow: hidden;
    display: grid;
    grid-template-columns: 1fr 1fr;
  }

  /* LEFT — content panel */
  .jgz-hero__left {
    position: relative;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    padding: 60px 60px 72px;
    z-index: 2;
  }

  .jgz-hero__grid-overlay {
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(rgba(184,151,90,0.04) 1px, transparent 1px),
      linear-gradient(90deg, rgba(184,151,90,0.04) 1px, transparent 1px);
    background-size: 60px 60px;
    pointer-events: none;
  }

  .jgz-hero__collection-label {
    position: absolute;
    top: 40px;
    left: 60px;
    font-family: 'Barlow', system-ui, sans-serif;
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: #b8975a;
    writing-mode: vertical-rl;
    transform: rotate(180deg);
  }

  .jgz-hero__eyebrow {
    font-family: 'Barlow', system-ui, sans-serif;
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: #b8975a;
    margin: 0 0 20px;
  }

  .jgz-hero__heading {
    font-family: 'Cormorant Garamond', Georgia, serif;
    font-size: 84px;
    font-weight: 300;
    line-height: 0.95;
    color: #f5f4f0;
    margin: 0 0 20px;
  }

  .jgz-hero__tagline {
    font-family: 'Cormorant Garamond', Georgia, serif;
    font-size: 20px;
    font-style: italic;
    color: #b8975a;
    margin: 0 0 16px;
  }

  .jgz-hero__subtext {
    font-family: 'Barlow', system-ui, sans-serif;
    font-size: 13px;
    font-weight: 300;
    color: #f5f4f0;
    opacity: 0.5;
    margin: 0 0 36px;
    line-height: 1.6;
  }

  .jgz-hero__ctas {
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
  }

  /* RIGHT — full-height image panel */
  .jgz-hero__right {
    position: relative;
    overflow: hidden;
    background: #141414;
  }

  .jgz-hero__right img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center top;
    display: block;
  }

  .jgz-hero__right-placeholder {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    color: rgba(245,244,240,0.12);
    font-family: 'Barlow', system-ui, sans-serif;
    font-size: 11px;
    letter-spacing: 0.15em;
    text-transform: uppercase;
  }

  /* subtle gradient on left edge of image for blend */
  .jgz-hero__right::before {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(to right, #0a0a0a 0%, transparent 12%);
    z-index: 1;
    pointer-events: none;
  }

  @media (max-width: 900px) {
    .jgz-hero {
      grid-template-columns: 1fr;
      height: auto;
      min-height: 100svh;
    }
    .jgz-hero__left {
      padding: 100px 24px 48px;
      order: 2;
    }
    .jgz-hero__collection-label { left: 24px; }
    .jgz-hero__heading { font-size: 52px; }
    .jgz-hero__right {
      order: 1;
      height: 55vw;
      min-height: 280px;
      max-height: 420px;
    }
    .jgz-hero__right::before { display: none; }
  }
</style>

<section class="jgz-hero">

  <!-- LEFT: text content -->
  <div class="jgz-hero__left">
    <div class="jgz-hero__grid-overlay"></div>
    <span class="jgz-hero__collection-label">SS 2026 Collection</span>
    <p class="jgz-hero__eyebrow">{{ section.settings.eyebrow }}</p>
    <h1 class="jgz-hero__heading">{{ section.settings.heading }}</h1>
    <p class="jgz-hero__tagline">{{ section.settings.tagline }}</p>
    <p class="jgz-hero__subtext">{{ section.settings.subtext }}</p>
    <div class="jgz-hero__ctas">
      <a href="{{ section.settings.cta_primary_url }}" class="jgz-btn-gold">{{ section.settings.cta_primary_label }}</a>
      <a href="{{ section.settings.cta_secondary_url }}" class="jgz-btn-ghost">{{ section.settings.cta_secondary_label }}</a>
    </div>
  </div>

  <!-- RIGHT: full-height image -->
  <div class="jgz-hero__right">
    {%- if section.settings.hero_image != blank -%}
      <img src="{{ section.settings.hero_image | image_url: width: 1400 }}" alt="{{ section.settings.heading }}" loading="eager">
    {%- else -%}
      <div class="jgz-hero__right-placeholder">Product Image</div>
    {%- endif -%}
  </div>

</section>

{% schema %}
{
  "name": "JIGERZ Hero",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow text", "default": "New Collection — Summer 2026" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Summer Essentials 2026" },
    { "type": "text", "id": "tagline", "label": "Tagline", "default": "Not Just A Brand — It's A Bond." },
    { "type": "textarea", "id": "subtext", "label": "Subtext", "default": "Premium imported fabrics. Modern silhouettes. Built for the Pakistani summer." },
    { "type": "text", "id": "cta_primary_label", "label": "Primary CTA label", "default": "Shop Now" },
    { "type": "url", "id": "cta_primary_url", "label": "Primary CTA link" },
    { "type": "text", "id": "cta_secondary_label", "label": "Secondary CTA label", "default": "Explore Collection" },
    { "type": "url", "id": "cta_secondary_url", "label": "Secondary CTA link" },
    { "type": "image_picker", "id": "hero_image", "label": "Hero product image" }
  ],
  "presets": [{ "name": "JIGERZ Hero" }]
}
{% endschema %}
