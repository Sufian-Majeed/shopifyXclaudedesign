<style>
  .jgz-footer {
    background: #060606;
    border-top: 1px solid rgba(255,255,255,0.08);
    padding: 72px 60px 0;
    font-family: 'Barlow', system-ui, sans-serif;
  }
  .jgz-footer-grid {
    display: grid;
    grid-template-columns: 2fr 1fr 1fr 1fr;
    gap: 60px;
    margin-bottom: 56px;
  }
  .jgz-footer-logo {
    height: 44px;
    filter: invert(1);
    margin-bottom: 16px;
    display: block;
  }
  .jgz-footer-tagline {
    font-size: 13px;
    color: #f5f4f0;
    opacity: 0.35;
    line-height: 1.7;
    max-width: 220px;
  }
  .jgz-footer-col-title {
    font-size: 10px;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: #b8975a;
    margin-bottom: 20px;
  }
  .jgz-footer-links {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 11px;
  }
  .jgz-footer-links a {
    color: #f5f4f0;
    text-decoration: none;
    font-size: 13px;
    opacity: 0.4;
    transition: opacity 0.2s;
  }
  .jgz-footer-links a:hover { opacity: 1; }

  .jgz-footer-bottom {
    border-top: 1px solid rgba(255,255,255,0.08);
    padding: 28px 0 36px;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }
  .jgz-footer-copy {
    font-size: 11px;
    color: #f5f4f0;
    opacity: 0.25;
  }
  .jgz-footer-socials {
    display: flex;
    gap: 20px;
  }
  .jgz-footer-socials a {
    font-size: 10px;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: #f5f4f0;
    text-decoration: none;
    opacity: 0.35;
    transition: opacity 0.2s;
  }
  .jgz-footer-socials a:hover { opacity: 1; }

  @media (max-width: 768px) {
    .jgz-footer { padding: 56px 20px 0; }
    .jgz-footer-grid { grid-template-columns: 1fr 1fr; gap: 28px; }
    .jgz-footer-bottom { flex-direction: column; gap: 14px; text-align: center; }
  }
</style>

<footer class="jgz-footer">
  <div class="jgz-footer-grid">
    <div>
      {%- if section.settings.logo != blank -%}
        <img src="{{ section.settings.logo | image_url: height: 88 }}" alt="{{ shop.name }}" class="jgz-footer-logo">
      {%- else -%}
        <div style="font-family:'Cormorant Garamond',Georgia,serif;font-size:28px;font-weight:300;color:#f5f4f0;letter-spacing:0.15em;margin-bottom:16px;">{{ shop.name | upcase }}</div>
      {%- endif -%}
      <p class="jgz-footer-tagline">Not Just A Brand — It's A Bond. Premium men's clothing for the modern Pakistani man.</p>
    </div>

    <div>
      <div class="jgz-footer-col-title">Shop</div>
      <ul class="jgz-footer-links">
        {%- for link in linklists[section.settings.shop_menu].links -%}
          <li><a href="{{ link.url }}">{{ link.title }}</a></li>
        {%- else -%}
          <li><a href="/collections/new-arrivals">New Arrivals</a></li>
          <li><a href="/collections/t-shirts">T-Shirts</a></li>
          <li><a href="/collections/polo">Polo</a></li>
          <li><a href="/collections/oversized">Oversized</a></li>
          <li><a href="/collections/sale">Sale</a></li>
        {%- endfor -%}
      </ul>
    </div>

    <div>
      <div class="jgz-footer-col-title">Help</div>
      <ul class="jgz-footer-links">
        {%- for link in linklists[section.settings.help_menu].links -%}
          <li><a href="{{ link.url }}">{{ link.title }}</a></li>
        {%- else -%}
          <li><a href="/pages/size-guide">Size Guide</a></li>
          <li><a href="/pages/delivery">Delivery Info</a></li>
          <li><a href="/pages/returns">Returns</a></li>
          <li><a href="/pages/track-order">Track Order</a></li>
          <li><a href="/pages/faq">FAQ</a></li>
        {%- endfor -%}
      </ul>
    </div>

    <div>
      <div class="jgz-footer-col-title">Brand</div>
      <ul class="jgz-footer-links">
        {%- for link in linklists[section.settings.brand_menu].links -%}
          <li><a href="{{ link.url }}">{{ link.title }}</a></li>
        {%- else -%}
          <li><a href="/pages/our-story">Our Story</a></li>
          <li><a href="/pages/quality">Quality Promise</a></li>
          <li><a href="/pages/contact">Contact Us</a></li>
          <li><a href="{{ section.settings.instagram_url }}">Instagram</a></li>
          <li><a href="{{ section.settings.tiktok_url }}">TikTok</a></li>
        {%- endfor -%}
      </ul>
    </div>
  </div>

  <div class="jgz-footer-bottom">
    <div class="jgz-footer-copy">© {{ 'now' | date: '%Y' }} {{ shop.name | upcase }}. All rights reserved. Pakistan.</div>
    <div class="jgz-footer-socials">
      {%- if section.settings.instagram_url != blank -%}
        <a href="{{ section.settings.instagram_url }}">Instagram</a>
      {%- endif -%}
      {%- if section.settings.tiktok_url != blank -%}
        <a href="{{ section.settings.tiktok_url }}">TikTok</a>
      {%- endif -%}
      {%- if section.settings.whatsapp_url != blank -%}
        <a href="{{ section.settings.whatsapp_url }}">WhatsApp</a>
      {%- endif -%}
    </div>
  </div>
</footer>

{% schema %}
{
  "name": "t:names.footer",
  "class": "section-wrapper",
  "blocks": [
    { "type": "_divider" },
    { "type": "@app" },
    { "type": "button" },
    { "type": "follow-on-shop" },
    { "type": "group" },
    { "type": "icon" },
    { "type": "image" },
    { "type": "menu" },
    { "type": "payment-icons" },
    { "type": "text" },
    { "type": "logo" },
    { "type": "jumbo-text" },
    { "type": "social-links" },
    { "type": "email-signup" }
  ],
  "enabled_on": { "groups": ["footer"] },
  "settings": [
    { "type": "image_picker", "id": "logo", "label": "Logo" },
    { "type": "text", "id": "shop_menu", "label": "Shop menu handle", "default": "footer-shop" },
    { "type": "text", "id": "help_menu", "label": "Help menu handle", "default": "footer-help" },
    { "type": "text", "id": "brand_menu", "label": "Brand menu handle", "default": "footer-brand" },
    { "type": "url", "id": "instagram_url", "label": "Instagram URL" },
    { "type": "url", "id": "tiktok_url", "label": "TikTok URL" },
    { "type": "url", "id": "whatsapp_url", "label": "WhatsApp URL" },
    { "type": "select", "id": "section_width", "label": "t:settings.width", "options": [{ "value": "page-width", "label": "t:options.page" }, { "value": "full-width", "label": "t:options.full" }], "default": "page-width" },
    { "type": "range", "id": "gap", "label": "t:settings.gap", "min": 0, "max": 100, "step": 1, "unit": "px", "default": 0 },
    { "type": "color_scheme", "id": "color_scheme", "label": "t:settings.color_scheme", "default": "scheme-1" },
    { "type": "header", "content": "t:content.padding" },
    { "type": "range", "id": "padding-block-start", "label": "t:settings.top", "min": 0, "max": 100, "step": 1, "unit": "px", "default": 20 },
    { "type": "range", "id": "padding-block-end", "label": "t:settings.bottom", "min": 0, "max": 100, "step": 1, "unit": "px", "default": 20 }
  ],
  "presets": [{ "name": "t:names.footer", "category": "t:categories.footer" }]
}
{% endschema %}
