<style>
  .jgz-newsletter {
    background: var(--jgz-black);
    padding: 80px var(--jgz-px);
    border-top: 1px solid var(--jgz-border);
    text-align: center;
  }

  .jgz-newsletter__inner {
    max-width: 520px;
    margin: 0 auto;
  }

  .jgz-newsletter__heading {
    font-family: var(--jgz-heading);
    font-size: 48px;
    font-weight: 300;
    color: var(--jgz-off-white);
    margin: 0 0 12px;
    line-height: 1.05;
  }

  .jgz-newsletter__sub {
    font-family: var(--jgz-body);
    font-size: 13px;
    font-weight: 300;
    color: var(--jgz-off-white);
    opacity: 0.5;
    margin: 0 0 36px;
  }

  .jgz-newsletter__form {
    display: flex;
    gap: 0;
    max-width: 440px;
    margin: 0 auto;
  }

  .jgz-newsletter__input {
    flex: 1;
    height: 48px;
    background: var(--jgz-card-bg);
    border: 1px solid var(--jgz-border);
    border-right: none;
    color: var(--jgz-off-white);
    font-family: var(--jgz-body);
    font-size: 13px;
    padding: 0 16px;
    outline: none;
  }
  .jgz-newsletter__input::placeholder {
    color: var(--jgz-off-white);
    opacity: 0.35;
  }
  .jgz-newsletter__input:focus {
    border-color: var(--jgz-gold);
  }

  .jgz-newsletter__btn {
    height: 48px;
    background: var(--jgz-gold);
    color: #0a0a0a;
    font-family: var(--jgz-body);
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    border: none;
    padding: 0 24px;
    cursor: pointer;
    white-space: nowrap;
    transition: opacity 0.2s;
  }
  .jgz-newsletter__btn:hover { opacity: 0.85; }

  @media (max-width: 768px) {
    .jgz-newsletter {
      padding: 60px var(--jgz-px-m);
    }
    .jgz-newsletter__heading { font-size: 36px; }
    .jgz-newsletter__form { flex-direction: column; gap: 8px; }
    .jgz-newsletter__input { border-right: 1px solid var(--jgz-border); }
    .jgz-newsletter__btn { width: 100%; }
  }
</style>

<section class="jgz-newsletter">
  <div class="jgz-newsletter__inner">
    <p class="jgz-section-label">{{ section.settings.section_label }}</p>
    <h2 class="jgz-newsletter__heading">{{ section.settings.heading }}</h2>
    <p class="jgz-newsletter__sub">{{ section.settings.subtext }}</p>

    {%- form 'customer', id: 'jgz-newsletter-form' -%}
      <input type="hidden" name="contact[tags]" value="newsletter">
      <div class="jgz-newsletter__form">
        <input
          type="email"
          name="contact[email]"
          class="jgz-newsletter__input"
          placeholder="{{ section.settings.placeholder }}"
          required
        >
        <button type="submit" class="jgz-newsletter__btn">{{ section.settings.button_label }}</button>
      </div>
      {%- if form.posted_successfully? -%}
        <p style="margin-top:16px;font-family:var(--jgz-body);font-size:13px;color:var(--jgz-gold);">You're in! Watch your inbox.</p>
      {%- endif -%}
    {%- endform -%}
  </div>
</section>

{% schema %}
{
  "name": "JIGERZ Newsletter",
  "settings": [
    { "type": "text", "id": "section_label", "label": "Section label", "default": "Stay in the Loop" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Drop Alerts & Exclusive Offers" },
    { "type": "text", "id": "subtext", "label": "Subtext", "default": "Be the first to know when new styles drop. No spam, ever." },
    { "type": "text", "id": "placeholder", "label": "Input placeholder", "default": "Enter your email" },
    { "type": "text", "id": "button_label", "label": "Button label", "default": "Subscribe" }
  ],
  "presets": [{ "name": "JIGERZ Newsletter" }]
}
{% endschema %}
