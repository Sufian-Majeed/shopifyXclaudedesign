<style>
  .jgz-newsletter {
    background: #0a0a0a;
    padding: 80px 60px;
    border-top: 1px solid rgba(255,255,255,0.08);
    text-align: center;
  }

  .jgz-newsletter__inner {
    max-width: 520px;
    margin: 0 auto;
  }

  .jgz-newsletter__label {
    font-family: 'Barlow', system-ui, sans-serif;
    font-size: 10px;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: #b8975a;
    margin: 0 0 16px;
  }

  .jgz-newsletter__heading {
    font-family: 'Cormorant Garamond', Georgia, serif;
    font-size: 48px;
    font-weight: 300;
    color: #f5f4f0;
    margin: 0 0 12px;
    line-height: 1.05;
  }

  .jgz-newsletter__sub {
    font-family: 'Barlow', system-ui, sans-serif;
    font-size: 13px;
    font-weight: 300;
    color: #f5f4f0;
    opacity: 0.5;
    margin: 0 0 36px;
  }

  .jgz-newsletter__form {
    display: flex;
    gap: 0;
    max-width: 440px;
    margin: 0 auto;
  }

  .jgz-newsletter__input {
    flex: 1;
    height: 48px;
    background: #141414;
    border: 1px solid rgba(255,255,255,0.2);
    border-right: none;
    color: #f5f4f0;
    font-family: 'Barlow', system-ui, sans-serif;
    font-size: 13px;
    padding: 0 16px;
    outline: none;
    min-width: 0;
  }
  .jgz-newsletter__input::placeholder {
    color: rgba(245,244,240,0.45);
  }
  .jgz-newsletter__input:focus {
    border-color: #b8975a;
  }

  .jgz-newsletter__btn {
    height: 48px;
    background: #b8975a;
    color: #0a0a0a;
    font-family: 'Barlow', system-ui, sans-serif;
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    border: none;
    padding: 0 24px;
    cursor: pointer;
    white-space: nowrap;
    transition: opacity 0.2s;
  }
  .jgz-newsletter__btn:hover { opacity: 0.85; }

  @media (max-width: 768px) {
    .jgz-newsletter {
      padding: 60px 20px;
    }
    .jgz-newsletter__heading { font-size: 36px; }
    .jgz-newsletter__form {
      flex-direction: column;
      gap: 10px;
      max-width: 100%;
      width: 100%;
    }
    .jgz-newsletter__input {
      border-right: 1px solid rgba(255,255,255,0.2);
      border-bottom: 1px solid rgba(255,255,255,0.2);
      width: 100%;
      height: 52px;
      font-size: 16px; /* prevents iOS zoom on focus */
    }
    .jgz-newsletter__btn {
      width: 100%;
      height: 52px;
    }
  }
</style>

<section class="jgz-newsletter">
  <div class="jgz-newsletter__inner">
    <p class="jgz-newsletter__label">{{ section.settings.section_label }}</p>
    <h2 class="jgz-newsletter__heading">{{ section.settings.heading }}</h2>
    <p class="jgz-newsletter__sub">{{ section.settings.subtext }}</p>

    {%- form 'customer', id: 'jgz-newsletter-form' -%}
      <input type="hidden" name="contact[tags]" value="newsletter">
      <div class="jgz-newsletter__form">
        <input
          type="email"
          name="contact[email]"
          class="jgz-newsletter__input"
          placeholder="{{ section.settings.placeholder }}"
          required
        >
        <button type="submit" class="jgz-newsletter__btn">{{ section.settings.button_label }}</button>
      </div>
      {%- if form.posted_successfully? -%}
        <p style="margin-top:16px;font-family:'Barlow',system-ui,sans-serif;font-size:13px;color:#b8975a;">You're in! Watch your inbox.</p>
      {%- endif -%}
    {%- endform -%}
  </div>
</section>

{% schema %}
{
  "name": "JIGERZ Newsletter",
  "settings": [
    { "type": "text", "id": "section_label", "label": "Section label", "default": "Stay in the Loop" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Drop Alerts & Exclusive Offers" },
    { "type": "text", "id": "subtext", "label": "Subtext", "default": "Be the first to know when new styles drop. No spam, ever." },
    { "type": "text", "id": "placeholder", "label": "Input placeholder", "default": "Enter your email" },
    { "type": "text", "id": "button_label", "label": "Button label", "default": "Subscribe" }
  ],
  "presets": [{ "name": "JIGERZ Newsletter" }]
}
{% endschema %}
