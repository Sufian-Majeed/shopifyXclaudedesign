<style>
  html, body, .shopify-section { background: #0a0a0a !important; color: #f5f4f0 !important; }
  * { box-sizing: border-box; }

  .jgz-col-page { background: #0a0a0a; min-height: 100vh; padding-bottom: 80px; }

  .jgz-col-header { padding: 60px 60px 0; border-bottom: 1px solid rgba(255,255,255,0.08); }
  .jgz-col-header__top { display: flex; align-items: flex-end; justify-content: space-between; padding-bottom: 32px; }
  .jgz-col-header__kicker { font-family: 'Barlow', system-ui, sans-serif; font-size: 10px; font-weight: 600; letter-spacing: 0.2em; text-transform: uppercase; color: #b8975a; margin: 0 0 10px; }
  .jgz-col-header__title { font-family: 'Cormorant Garamond', Georgia, serif; font-size: 64px; font-weight: 300; color: #f5f4f0; margin: 0; line-height: 1; }
  .jgz-col-header__count { font-family: 'Barlow', system-ui, sans-serif; font-size: 11px; letter-spacing: 0.1em; color: #f5f4f0; opacity: 0.35; text-transform: uppercase; margin-bottom: 4px; }

  .jgz-col-layout { display: grid; grid-template-columns: 220px 1fr; gap: 0; padding: 0 60px; align-items: start; }

  .jgz-sidebar { position: sticky; top: 80px; padding: 32px 32px 32px 0; border-right: 1px solid rgba(255,255,255,0.08); min-height: 300px; }
  .jgz-sidebar__title { font-family: 'Barlow', system-ui, sans-serif; font-size: 10px; font-weight: 600; letter-spacing: 0.2em; text-transform: uppercase; color: #b8975a; margin: 0 0 16px; padding-bottom: 10px; border-bottom: 1px solid rgba(255,255,255,0.08); }
  .jgz-sidebar__section { margin-bottom: 32px; }
  .jgz-sidebar__options { display: flex; flex-wrap: wrap; gap: 6px; }
  .jgz-size-pill { font-family: 'Barlow', system-ui, sans-serif; font-size: 11px; font-weight: 500; letter-spacing: 0.05em; color: #f5f4f0; border: 1px solid rgba(255,255,255,0.08); padding: 6px 14px; cursor: pointer; min-width: 44px; text-align: center; background: none; transition: border-color 0.2s, color 0.2s; }
  .jgz-size-pill:hover { border-color: #b8975a; color: #b8975a; }
  .jgz-checkbox-label { display: flex; align-items: center; gap: 10px; font-family: 'Barlow', system-ui, sans-serif; font-size: 12px; color: #f5f4f0; opacity: 0.75; cursor: pointer; margin-bottom: 10px; }
  .jgz-checkbox-label input[type="checkbox"] { accent-color: #b8975a; }

  .jgz-col-main { padding: 32px 0 32px 32px; }
  .jgz-sort-row { display: flex; align-items: center; justify-content: space-between; margin-bottom: 28px; padding-bottom: 20px; border-bottom: 1px solid rgba(255,255,255,0.08); }
  .jgz-sort-row__count { font-family: 'Barlow', system-ui, sans-serif; font-size: 12px; color: #f5f4f0; opacity: 0.4; }
  .jgz-sort-select { background: #141414; border: 1px solid rgba(255,255,255,0.08); color: #f5f4f0; font-family: 'Barlow', system-ui, sans-serif; font-size: 11px; padding: 8px 12px; cursor: pointer; outline: none; }

  .jgz-col-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 24px; }

  .jgz-product-card { display: block; text-decoration: none; background: #0a0a0a; color: #f5f4f0; }
  .jgz-product-card__image-wrap { position: relative; aspect-ratio: 3/4; background: #141414; overflow: hidden; }
  .jgz-product-card__image-wrap img { width: 100% !important; height: 100% !important; object-fit: cover !important; display: block !important; opacity: 1 !important; visibility: visible !important; transition: transform 0.5s ease; }
  .jgz-product-card:hover .jgz-product-card__image-wrap img { transform: scale(1.04); }
  .jgz-product-card__quick-add { position: absolute; bottom: 0; left: 0; right: 0; background: rgba(10,10,10,0.92); color: #b8975a; font-family: 'Barlow', system-ui, sans-serif; font-size: 11px; font-weight: 600; letter-spacing: 0.2em; text-transform: uppercase; text-align: center; padding: 14px; transform: translateY(100%); transition: transform 0.25s ease; cursor: pointer; }
  .jgz-product-card:hover .jgz-product-card__quick-add { transform: translateY(0); }
  .jgz-product-card__badges { position: absolute; top: 12px; left: 12px; display: flex; flex-direction: column; gap: 4px; z-index: 2; }
  .jgz-badge { font-family: 'Barlow', system-ui, sans-serif; font-size: 9px; font-weight: 600; letter-spacing: 0.12em; text-transform: uppercase; padding: 4px 10px; }
  .jgz-badge--new { background: #b8975a; color: #0a0a0a; }
  .jgz-badge--sale { background: #e85d04; color: #fff; }

  .jgz-product-card__info { padding: 14px 0 8px; }
  .jgz-product-card__name { font-family: 'Barlow', system-ui, sans-serif; font-size: 13px; font-weight: 400; color: #f5f4f0; margin: 0 0 6px; }
  .jgz-product-card__price-row { display: flex; align-items: baseline; gap: 8px; flex-wrap: wrap; }
  .jgz-product-card__price { font-family: 'Cormorant Garamond', Georgia, serif; font-size: 18px; font-weight: 600; color: #b8975a; }
  .jgz-product-card__compare { font-size: 13px; color: #f5f4f0; opacity: 0.35; text-decoration: line-through; }
  .jgz-product-card__save { font-family: 'Barlow', system-ui, sans-serif; font-size: 10px; font-weight: 600; color: #e85d04; }

  .jgz-pagination { display: flex; justify-content: center; gap: 4px; margin-top: 48px; }
  .jgz-pagination a, .jgz-pagination span { width: 36px; height: 36px; display: flex; align-items: center; justify-content: center; font-family: 'Barlow', system-ui, sans-serif; font-size: 12px; border: 1px solid rgba(255,255,255,0.08); color: #f5f4f0; text-decoration: none; }
  .jgz-pagination a:hover { border-color: #b8975a; color: #b8975a; }
  .jgz-pagination span { color: #b8975a; border-color: #b8975a; }

  @media (max-width: 768px) {
    .jgz-col-header { padding: 40px 20px 0; }
    .jgz-col-header__title { font-size: 40px; }
    .jgz-col-layout { grid-template-columns: 1fr; padding: 0 20px; }
    .jgz-sidebar { display: none; }
    .jgz-col-main { padding: 24px 0; }
    .jgz-col-grid { grid-template-columns: repeat(2, 1fr); gap: 12px; }
    .jgz-product-card__quick-add { display: none; }
  }
</style>

{%- paginate collection.products by 24 -%}
<div class="jgz-col-page">

  <div class="jgz-col-header">
    <div class="jgz-col-header__top">
      <div>
        <p class="jgz-col-header__kicker">JIGERZ</p>
        <h1 class="jgz-col-header__title">{{ collection.title }}</h1>
      </div>
      <p class="jgz-col-header__count">{{ collection.products_count }} Products</p>
    </div>
  </div>

  <div class="jgz-col-layout">
    <aside class="jgz-sidebar">
      <div class="jgz-sidebar__section">
        <h3 class="jgz-sidebar__title">Category</h3>
        {%- for link in linklists['main-menu'].links -%}
          <label class="jgz-checkbox-label"><input type="checkbox"> {{ link.title }}</label>
        {%- endfor -%}
      </div>
      <div class="jgz-sidebar__section">
        <h3 class="jgz-sidebar__title">Size</h3>
        <div class="jgz-sidebar__options">
          {%- for size in 'XS,S,M,L,XL,XXL' | split: ',' -%}
            <button class="jgz-size-pill">{{ size }}</button>
          {%- endfor -%}
        </div>
      </div>
      <div class="jgz-sidebar__section">
        <h3 class="jgz-sidebar__title">Availability</h3>
        <label class="jgz-checkbox-label"><input type="checkbox" checked> In Stock</label>
        <label class="jgz-checkbox-label"><input type="checkbox"> Out of Stock</label>
      </div>
    </aside>

    <div class="jgz-col-main">
      <div class="jgz-sort-row">
        <span class="jgz-sort-row__count">{{ collection.products_count }} products</span>
        <select class="jgz-sort-select" onchange="window.location.href=this.value">
          {%- for option in collection.sort_options -%}
            <option value="{{ collection.url }}?sort_by={{ option.value }}"{% if collection.sort_by == option.value %} selected{% endif %}>{{ option.name }}</option>
          {%- endfor -%}
        </select>
      </div>

      <div class="jgz-col-grid">
        {%- for product in collection.products -%}
          {%- assign savings_percent = 0 -%}
          {%- if product.compare_at_price > product.price -%}
            {%- assign savings = product.compare_at_price | minus: product.price -%}
            {%- assign savings_percent = savings | times: 100 | divided_by: product.compare_at_price -%}
          {%- endif -%}

          <a href="{{ product.url }}" class="jgz-product-card">
            <div class="jgz-product-card__image-wrap">
              {%- if product.featured_image != blank -%}
                <img
                  src="{{ product.featured_image | image_url: width: 800 }}"
                  srcset="{{ product.featured_image | image_url: width: 400 }} 400w, {{ product.featured_image | image_url: width: 800 }} 800w"
                  sizes="(max-width: 768px) 50vw, 33vw"
                  alt="{{ product.title | escape }}"
                  loading="eager"
                  style="width:100%;height:100%;object-fit:cover;display:block;opacity:1;visibility:visible;"
                >
              {%- else -%}
                <div style="width:100%;height:100%;display:flex;align-items:center;justify-content:center;color:rgba(245,244,240,0.1);font-family:'Barlow',system-ui,sans-serif;font-size:11px;letter-spacing:0.1em;text-transform:uppercase;">No Image</div>
              {%- endif -%}
              <div class="jgz-product-card__badges">
                {%- if product.tags contains 'new-arrival' -%}<span class="jgz-badge jgz-badge--new">New</span>{%- endif -%}
                {%- if savings_percent > 0 -%}<span class="jgz-badge jgz-badge--sale">Sale</span>{%- endif -%}
              </div>
              <div class="jgz-product-card__quick-add">Quick Add +</div>
            </div>
            <div class="jgz-product-card__info">
              <p class="jgz-product-card__name">{{ product.title }}</p>
              <div class="jgz-product-card__price-row">
                <span class="jgz-product-card__price">{{ product.price | money }}</span>
                {%- if product.compare_at_price > product.price -%}
                  <span class="jgz-product-card__compare">{{ product.compare_at_price | money }}</span>
                  <span class="jgz-product-card__save">-{{ savings_percent }}%</span>
                {%- endif -%}
              </div>
            </div>
          </a>
        {%- endfor -%}
      </div>

      {%- if paginate.pages > 1 -%}
        <div class="jgz-pagination">
          {%- if paginate.previous -%}<a href="{{ paginate.previous.url }}">‹</a>{%- endif -%}
          {%- for part in paginate.parts -%}
            {%- if part.is_link -%}<a href="{{ part.url }}">{{ part.title }}</a>{%- else -%}<span>{{ part.title }}</span>{%- endif -%}
          {%- endfor -%}
          {%- if paginate.next -%}<a href="{{ paginate.next.url }}">›</a>{%- endif -%}
        </div>
      {%- endif -%}
    </div>
  </div>
</div>
{%- endpaginate -%}

{% schema %}
{
  "name": "t:names.collection_container",
  "enabled_on": {
    "templates": ["collection"]
  },
  "settings": [],
  "presets": []
}
{% endschema %}
