<style>
  html, body, .shopify-section { background: #0a0a0a !important; color: #f5f4f0 !important; }
  * { box-sizing: border-box; }

  .jgz-breadcrumb { padding: 18px 60px; font-size: 10px; letter-spacing: 0.2em; text-transform: uppercase; opacity: 0.35; border-bottom: 1px solid rgba(255,255,255,0.08); font-family: 'Barlow', system-ui, sans-serif; }
  .jgz-breadcrumb a { color: #f5f4f0; text-decoration: none; }
  .jgz-breadcrumb a:hover { color: #b8975a; }

  .jgz-pdp { display: grid; grid-template-columns: 1fr 1fr; min-height: 90vh; background: #0a0a0a; }

  /* GALLERY */
  .jgz-gallery { display: grid; grid-template-columns: 76px 1fr; gap: 3px; padding: 40px 0 40px 60px; position: sticky; top: 72px; height: calc(100vh - 72px); }
  .jgz-gallery-thumbs { display: flex; flex-direction: column; gap: 3px; overflow-y: auto; }
  .jgz-gallery-thumb { aspect-ratio: 3/4; background: #141414; cursor: pointer; border: 2px solid transparent; transition: border-color 0.2s; overflow: hidden; flex-shrink: 0; }
  .jgz-gallery-thumb img { width: 100%; height: 100%; object-fit: cover; }
  .jgz-gallery-thumb.active { border-color: #b8975a; }
  .jgz-gallery-thumb:hover { border-color: rgba(184,151,90,0.5); }
  .jgz-gallery-main { background: #141414; position: relative; overflow: hidden; }
  .jgz-gallery-main img { width: 100%; height: 100%; object-fit: cover; display: block; }
  .jgz-gallery-zoom { position: absolute; bottom: 20px; right: 20px; font-size: 10px; letter-spacing: 0.15em; text-transform: uppercase; opacity: 0.3; cursor: pointer; color: #f5f4f0; font-family: 'Barlow', system-ui, sans-serif; }
  .jgz-gallery-nav { position: absolute; top: 50%; transform: translateY(-50%); display: flex; justify-content: space-between; width: 100%; padding: 0 16px; pointer-events: none; }
  .jgz-gallery-nav-btn { width: 40px; height: 40px; border: 1px solid rgba(255,255,255,0.08); background: rgba(10,10,10,0.7); color: #f5f4f0; display: flex; align-items: center; justify-content: center; cursor: pointer; pointer-events: all; font-size: 16px; transition: all 0.2s; }
  .jgz-gallery-nav-btn:hover { border-color: #b8975a; color: #b8975a; }

  /* INFO */
  .jgz-product-info { padding: 40px 60px 100px 48px; overflow-y: auto; background: #0a0a0a; }

  .jgz-product-badge-row { display: flex; gap: 8px; margin-bottom: 16px; flex-wrap: wrap; }
  .jgz-p-badge { font-size: 9px; font-weight: 600; letter-spacing: 0.15em; text-transform: uppercase; padding: 5px 12px; border: 1px solid #b8975a; color: #b8975a; font-family: 'Barlow', system-ui, sans-serif; }
  .jgz-p-badge.filled { background: #b8975a; color: #0a0a0a; }
  .jgz-p-badge.cod { background: #1a3a1a; color: #4caf50; border-color: #4caf50; }

  .jgz-product-title { font-family: 'Cormorant Garamond', Georgia, serif; font-size: 44px; font-weight: 300; line-height: 1.05; margin-bottom: 6px; color: #f5f4f0; }
  .jgz-product-sku { font-size: 10px; opacity: 0.3; letter-spacing: 0.2em; margin-bottom: 16px; color: #f5f4f0; font-family: 'Barlow', system-ui, sans-serif; text-transform: uppercase; }

  .jgz-rating-row { display: flex; align-items: center; gap: 10px; margin-bottom: 20px; padding-bottom: 20px; border-bottom: 1px solid rgba(255,255,255,0.08); flex-wrap: wrap; }
  .jgz-stars { color: #b8975a; font-size: 13px; letter-spacing: 2px; }
  .jgz-rating-count { font-size: 11px; opacity: 0.4; color: #f5f4f0; font-family: 'Barlow', system-ui, sans-serif; }
  .jgz-rating-link { font-size: 11px; color: #b8975a; text-decoration: none; opacity: 0.7; border-bottom: 1px solid transparent; transition: all 0.2s; font-family: 'Barlow', system-ui, sans-serif; }
  .jgz-rating-link:hover { opacity: 1; border-color: #b8975a; }

  .jgz-compare-price-box { background: rgba(184,151,90,0.08); border: 1px solid rgba(184,151,90,0.25); padding: 16px 20px; margin-bottom: 20px; display: flex; align-items: center; justify-content: space-between; flex-wrap: wrap; gap: 8px; }
  .jgz-compare-label { font-size: 10px; letter-spacing: 0.2em; text-transform: uppercase; opacity: 0.5; margin-bottom: 4px; color: #f5f4f0; font-family: 'Barlow', system-ui, sans-serif; }
  .jgz-compare-prices { display: flex; align-items: baseline; gap: 12px; }
  .jgz-compare-now { font-family: 'Cormorant Garamond', Georgia, serif; font-size: 32px; font-weight: 600; color: #b8975a; }
  .jgz-compare-was { font-size: 16px; opacity: 0.4; text-decoration: line-through; color: #f5f4f0; }
  .jgz-compare-save-pill { background: #b8975a; color: #0a0a0a; font-size: 10px; font-weight: 700; letter-spacing: 0.1em; padding: 6px 14px; font-family: 'Barlow', system-ui, sans-serif; }

  .jgz-stock-indicator { display: flex; align-items: center; gap: 8px; margin-bottom: 20px; font-size: 12px; font-family: 'Barlow', system-ui, sans-serif; }
  .jgz-stock-dot { width: 8px; height: 8px; border-radius: 50%; background: #e85d04; animation: jgzPulse 1.5s infinite; flex-shrink: 0; }
  @keyframes jgzPulse { 0%,100%{opacity:1;}50%{opacity:0.4;} }
  .jgz-stock-text { color: #e85d04; font-weight: 500; letter-spacing: 0.05em; }
  .jgz-stock-sub { opacity: 0.45; font-size: 11px; color: #f5f4f0; }

  .jgz-product-bullets { margin-bottom: 24px; display: flex; flex-direction: column; gap: 8px; }
  .jgz-bullet-item { display: flex; align-items: center; gap: 10px; font-size: 12px; opacity: 0.75; color: #f5f4f0; font-family: 'Barlow', system-ui, sans-serif; }
  .jgz-bullet-check { color: #b8975a; font-size: 14px; flex-shrink: 0; }

  .jgz-option-section { margin-bottom: 24px; }
  .jgz-option-label { font-size: 10px; letter-spacing: 0.2em; text-transform: uppercase; opacity: 0.5; margin-bottom: 10px; display: flex; justify-content: space-between; align-items: center; color: #f5f4f0; font-family: 'Barlow', system-ui, sans-serif; }
  .jgz-option-selected { color: #b8975a; opacity: 1; font-weight: 500; }
  .jgz-color-options { display: flex; gap: 10px; }
  .jgz-color-opt { width: 30px; height: 30px; border-radius: 50%; cursor: pointer; border: 2px solid transparent; transition: all 0.2s; outline: 1px solid rgba(255,255,255,0.08); }
  .jgz-color-opt.active { border-color: #b8975a; outline-color: #b8975a; }
  .jgz-color-opt:hover { transform: scale(1.1); }

  .jgz-size-grid { display: flex; flex-wrap: wrap; gap: 8px; }
  .jgz-size-opt { min-width: 50px; padding: 9px 14px; border: 1px solid rgba(255,255,255,0.08); font-size: 12px; letter-spacing: 0.1em; text-align: center; cursor: pointer; transition: all 0.2s; opacity: 0.55; background: none; color: #f5f4f0; font-family: 'Barlow', system-ui, sans-serif; }
  .jgz-size-opt:hover { border-color: rgba(255,255,255,0.3); opacity: 1; }
  .jgz-size-opt.active { border-color: #b8975a; color: #b8975a; opacity: 1; }
  .jgz-size-opt.soldout { opacity: 0.2; text-decoration: line-through; cursor: not-allowed; }
  .jgz-size-guide-link { font-size: 10px; color: #b8975a; text-decoration: none; letter-spacing: 0.1em; font-family: 'Barlow', system-ui, sans-serif; }
  .jgz-size-guide-link:hover { border-bottom: 1px solid #b8975a; }

  .jgz-delivery-line { display: flex; align-items: center; gap: 10px; background: rgba(255,255,255,0.03); border: 1px solid rgba(255,255,255,0.08); padding: 12px 16px; margin-bottom: 20px; font-size: 12px; opacity: 0.75; color: #f5f4f0; font-family: 'Barlow', system-ui, sans-serif; }

  .jgz-add-row { display: grid; grid-template-columns: 110px 1fr; gap: 10px; margin-bottom: 12px; }
  .jgz-qty-control { display: flex; align-items: center; border: 1px solid rgba(255,255,255,0.08); background: #141414; }
  .jgz-qty-btn { width: 34px; height: 48px; background: none; border: none; color: #f5f4f0; font-size: 18px; cursor: pointer; opacity: 0.5; transition: opacity 0.2s; font-family: 'Barlow', system-ui, sans-serif; }
  .jgz-qty-btn:hover { opacity: 1; }
  .jgz-qty-val { flex: 1; text-align: center; font-size: 14px; color: #f5f4f0; }
  .jgz-add-to-cart { background: #b8975a; color: #0a0a0a; border: none; font-family: 'Barlow', system-ui, sans-serif; font-size: 12px; font-weight: 600; letter-spacing: 0.2em; text-transform: uppercase; cursor: pointer; transition: all 0.2s; height: 48px; }
  .jgz-add-to-cart:hover { background: #f5f4f0; }
  .jgz-add-to-cart.added { background: #2e7d32 !important; color: white !important; }
  .jgz-buy-now { width: 100%; background: none; border: 1px solid rgba(255,255,255,0.08); color: #f5f4f0; font-family: 'Barlow', system-ui, sans-serif; font-size: 12px; letter-spacing: 0.2em; text-transform: uppercase; cursor: pointer; height: 48px; transition: all 0.2s; margin-bottom: 20px; }
  .jgz-buy-now:hover { border-color: #b8975a; color: #b8975a; }

  .jgz-trust-badges { display: grid; grid-template-columns: repeat(4, 1fr); gap: 12px; padding: 20px 0; border-top: 1px solid rgba(255,255,255,0.08); border-bottom: 1px solid rgba(255,255,255,0.08); margin-bottom: 28px; }
  .jgz-trust-badge { text-align: center; }
  .jgz-trust-badge-icon { font-size: 18px; margin-bottom: 5px; opacity: 0.6; }
  .jgz-trust-badge-text { font-size: 9px; letter-spacing: 0.08em; text-transform: uppercase; opacity: 0.45; line-height: 1.5; color: #f5f4f0; font-family: 'Barlow', system-ui, sans-serif; }

  .jgz-accordion { border-top: 1px solid rgba(255,255,255,0.08); }
  .jgz-accordion-item { border-bottom: 1px solid rgba(255,255,255,0.08); }
  .jgz-accordion-header { width: 100%; background: none; border: none; color: #f5f4f0; font-family: 'Barlow', system-ui, sans-serif; font-size: 11px; letter-spacing: 0.2em; text-transform: uppercase; padding: 16px 0; display: flex; justify-content: space-between; align-items: center; cursor: pointer; opacity: 0.7; transition: opacity 0.2s; }
  .jgz-accordion-header:hover { opacity: 1; }
  .jgz-accordion-icon { font-size: 18px; transition: transform 0.3s; }
  .jgz-accordion-item.open .jgz-accordion-icon { transform: rotate(45deg); }
  .jgz-accordion-body { display: none; padding-bottom: 18px; font-size: 13px; line-height: 1.8; opacity: 0.55; color: #f5f4f0; font-family: 'Barlow', system-ui, sans-serif; }
  .jgz-accordion-item.open .jgz-accordion-body { display: block; }
  .jgz-accordion-body ul { list-style: none; display: flex; flex-direction: column; gap: 6px; padding: 0; }
  .jgz-accordion-body li::before { content: '— '; color: #b8975a; }

  .jgz-related { padding: 72px 60px; border-top: 1px solid rgba(255,255,255,0.08); background: #0a0a0a; }
  .jgz-related-label { font-size: 10px; letter-spacing: 0.3em; text-transform: uppercase; color: #b8975a; margin-bottom: 12px; font-family: 'Barlow', system-ui, sans-serif; }
  .jgz-related-title { font-family: 'Cormorant Garamond', Georgia, serif; font-size: 38px; font-weight: 300; margin-bottom: 40px; color: #f5f4f0; }
  .jgz-related-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 20px; }
  .jgz-r-card { cursor: pointer; text-decoration: none; display: block; }
  .jgz-r-img { aspect-ratio: 3/4; background: #141414; margin-bottom: 12px; overflow: hidden; }
  .jgz-r-img img { width: 100%; height: 100%; object-fit: cover; transition: transform 0.4s; }
  .jgz-r-card:hover .jgz-r-img img { transform: scale(1.04); }
  .jgz-r-name { font-size: 13px; margin-bottom: 5px; color: #f5f4f0; font-family: 'Barlow', system-ui, sans-serif; }
  .jgz-r-prices { display: flex; gap: 8px; align-items: baseline; }
  .jgz-r-price { font-family: 'Cormorant Garamond', Georgia, serif; font-size: 17px; color: #b8975a; }
  .jgz-r-price-old { font-size: 12px; opacity: 0.35; text-decoration: line-through; color: #f5f4f0; }

  .jgz-sticky-cta { display: none; position: fixed; bottom: 0; left: 0; right: 0; z-index: 50; background: rgba(10,10,10,0.97); border-top: 1px solid rgba(255,255,255,0.08); padding: 12px 20px; gap: 12px; align-items: center; backdrop-filter: blur(10px); }
  .jgz-sticky-cta-info { flex: 1; }
  .jgz-sticky-cta-name { font-size: 13px; font-weight: 400; color: #f5f4f0; font-family: 'Barlow', system-ui, sans-serif; }
  .jgz-sticky-cta-price { font-family: 'Cormorant Garamond', Georgia, serif; font-size: 18px; color: #b8975a; }
  .jgz-sticky-cta-btn { background: #b8975a; color: #0a0a0a; border: none; padding: 12px 28px; font-family: 'Barlow', system-ui, sans-serif; font-size: 11px; font-weight: 600; letter-spacing: 0.15em; text-transform: uppercase; cursor: pointer; }

  @media (max-width: 768px) {
    .jgz-breadcrumb { padding: 12px 20px; }
    .jgz-pdp { grid-template-columns: 1fr; }
    .jgz-gallery { grid-template-columns: 1fr; padding: 0; position: relative; top: auto; height: auto; }
    .jgz-gallery-thumbs { flex-direction: row; padding: 8px 16px; gap: 6px; overflow-x: auto; overflow-y: visible; }
    .jgz-gallery-thumb { width: 56px; height: 75px; aspect-ratio: unset; flex-shrink: 0; }
    .jgz-gallery-main { height: 400px; }
    .jgz-product-info { padding: 24px 20px 120px; }
    .jgz-product-title { font-size: 34px; }
    .jgz-trust-badges { grid-template-columns: repeat(2, 1fr); }
    .jgz-add-row { grid-template-columns: 90px 1fr; }
    .jgz-related { padding: 48px 20px; }
    .jgz-related-title { font-size: 28px; margin-bottom: 24px; }
    .jgz-related-grid { grid-template-columns: repeat(2, 1fr); gap: 12px; }
    .jgz-sticky-cta { display: flex; }
  }
</style>

{%- assign current_variant = product.selected_or_first_available_variant -%}
{%- assign savings_percent = 0 -%}
{%- if product.compare_at_price > product.price -%}
  {%- assign savings = product.compare_at_price | minus: product.price -%}
  {%- assign savings_percent = savings | times: 100 | divided_by: product.compare_at_price -%}
{%- endif -%}



<!-- Breadcrumb -->
<div class="jgz-breadcrumb">
  <a href="/">Home</a> &nbsp;/&nbsp;
  {%- if product.collections.first -%}
    <a href="{{ product.collections.first.url }}">{{ product.collections.first.title }}</a> &nbsp;/&nbsp;
  {%- endif -%}
  {{ product.title }}
</div>

<div class="jgz-pdp">

  <!-- GALLERY -->
  <div class="jgz-gallery">
    <div class="jgz-gallery-thumbs">
      {%- for image in product.images limit: 8 -%}
        <div class="jgz-gallery-thumb {% if forloop.first %}active{% endif %}"
             onclick="jgzThumb(this, '{{ image | image_url: width: 1200 }}')"
             data-idx="{{ forloop.index0 }}">
          <img src="{{ image | image_url: width: 160 }}" alt="{{ product.title }}" loading="lazy">
        </div>
      {%- else -%}
        <div class="jgz-gallery-thumb active" style="background:#141414;"></div>
      {%- endfor -%}
    </div>
    <div class="jgz-gallery-main">
      {%- if product.featured_image -%}
        <img id="jgzMainImg" src="{{ product.featured_image | image_url: width: 1200 }}" alt="{{ product.title }}" loading="eager">
      {%- else -%}
        <div style="width:100%;height:100%;display:flex;align-items:center;justify-content:center;color:rgba(255,255,255,0.15);font-family:'Barlow', system-ui, sans-serif;font-size:11px;letter-spacing:0.1em;">No Image</div>
      {%- endif -%}
      <div class="jgz-gallery-zoom">+ Zoom</div>
      <div class="jgz-gallery-nav">
        <button class="jgz-gallery-nav-btn" onclick="jgzNavImg(-1)">‹</button>
        <button class="jgz-gallery-nav-btn" onclick="jgzNavImg(1)">›</button>
      </div>
    </div>
  </div>

  <!-- PRODUCT INFO -->
  <div class="jgz-product-info">

    <div class="jgz-product-badge-row">
      {%- if product.tags contains 'new-arrival' -%}
        <span class="jgz-p-badge filled">New Arrival</span>
      {%- endif -%}
      {%- if current_variant.available -%}
        <span class="jgz-p-badge">In Stock</span>
      {%- endif -%}
      <span class="jgz-p-badge cod">💵 Cash on Delivery</span>
    </div>

    <h1 class="jgz-product-title">{{ product.title }}</h1>
    {%- if current_variant.sku != blank -%}
      <div class="jgz-product-sku">SKU: {{ current_variant.sku }}</div>
    {%- endif -%}

    <div class="jgz-rating-row">
      <div class="jgz-stars">★★★★★</div>
      <span class="jgz-rating-count">4.9 / 5</span>
      <a href="#reviews" class="jgz-rating-link">48 Reviews</a>
    </div>

    <!-- PRICE BOX -->
    <div class="jgz-compare-price-box">
      <div>
        <div class="jgz-compare-label">Compare at Price</div>
        <div class="jgz-compare-prices">
          <span class="jgz-compare-now" id="jgzPrice">{{ current_variant.price | money }}</span>
          {%- if product.compare_at_price > product.price -%}
            <span class="jgz-compare-was">{{ product.compare_at_price | money }}</span>
          {%- endif -%}
        </div>
      </div>
      {%- if savings_percent > 0 -%}
        <span class="jgz-compare-save-pill">SAVE {{ savings_percent }}%</span>
      {%- endif -%}
    </div>

    <!-- STOCK -->
    {%- if current_variant.inventory_management == 'shopify' and current_variant.inventory_quantity > 0 and current_variant.inventory_quantity < 10 -%}
      <div class="jgz-stock-indicator">
        <div class="jgz-stock-dot"></div>
        <span class="jgz-stock-text">Only {{ current_variant.inventory_quantity }} pieces left!</span>
        <span class="jgz-stock-sub">— Order soon</span>
      </div>
    {%- endif -%}

    <!-- BULLETS -->
    <div class="jgz-product-bullets">
      <div class="jgz-bullet-item"><span class="jgz-bullet-check">✓</span> Premium Imported Fabric — 100% Ring-Spun Cotton</div>
      <div class="jgz-bullet-item"><span class="jgz-bullet-check">✓</span> Stretchable &amp; Breathable — Perfect for Summer</div>
      <div class="jgz-bullet-item"><span class="jgz-bullet-check">✓</span> Smart Fit Design — Modern Relaxed Silhouette</div>
    </div>

    {%- form 'product', product, id: 'jgz-product-form' -%}
      <input type="hidden" name="id" id="jgzVariantId" value="{{ current_variant.id }}">
      <input type="hidden" name="quantity" id="jgzQtyHidden" value="1">

      {%- for option in product.options_with_values -%}
        <div class="jgz-option-section">
          {%- if option.name == 'Color' or option.name == 'Colour' -%}
            <div class="jgz-option-label">
              {{ option.name }}
              <span class="jgz-option-selected" id="jgzColorName">{{ option.selected_value }}</span>
            </div>
            <div class="jgz-color-options">
              {%- for value in option.values -%}
                <div class="jgz-color-opt {% if option.selected_value == value %}active{% endif %}"
                     style="background: {{ value | downcase }};"
                     title="{{ value }}"
                     onclick="jgzSelectColor(this, {{ option.position }}, '{{ value }}')">
                </div>
              {%- endfor -%}
            </div>
          {%- else -%}
            <div class="jgz-option-label">
              {{ option.name }}
              {%- if option.name == 'Size' -%}
                <a href="#" class="jgz-size-guide-link">Size Guide →</a>
              {%- endif -%}
            </div>
            <div class="jgz-size-grid">
              {%- for value in option.values -%}
                <div class="jgz-size-opt {% if option.selected_value == value %}active{% endif %}"
                     onclick="jgzSelectSize(this, {{ option.position }}, '{{ value }}')">
                  {{ value }}
                </div>
              {%- endfor -%}
            </div>
          {%- endif -%}
        </div>
      {%- endfor -%}

      <!-- DELIVERY -->
      <div class="jgz-delivery-line">
        <span>🚚</span>
        <span>Order now &amp; get delivery in <strong>3–5 business days</strong> · Free on orders PKR 2,500+</span>
      </div>

      <!-- ADD TO CART -->
      <div class="jgz-add-row">
        <div class="jgz-qty-control">
          <button type="button" class="jgz-qty-btn" onclick="jgzQty(-1)">−</button>
          <span class="jgz-qty-val" id="jgzQtyDisplay">1</span>
          <button type="button" class="jgz-qty-btn" onclick="jgzQty(1)">+</button>
        </div>
        <button type="submit" name="add" class="jgz-add-to-cart" id="jgzAtcBtn">
          {%- if current_variant.available -%}Add to Bag{%- else -%}Sold Out{%- endif -%}
        </button>
      </div>

      <button type="button" class="jgz-buy-now">Buy Now — {{ current_variant.price | money }}</button>

    {%- endform -%}

    <!-- TRUST -->
    <div class="jgz-trust-badges">
      <div class="jgz-trust-badge"><div class="jgz-trust-badge-icon">🚚</div><div class="jgz-trust-badge-text">Free<br>Shipping</div></div>
      <div class="jgz-trust-badge"><div class="jgz-trust-badge-icon">💵</div><div class="jgz-trust-badge-text">Cash on<br>Delivery</div></div>
      <div class="jgz-trust-badge"><div class="jgz-trust-badge-icon">↩</div><div class="jgz-trust-badge-text">30-Day<br>Returns</div></div>
      <div class="jgz-trust-badge"><div class="jgz-trust-badge-icon">✓</div><div class="jgz-trust-badge-text">Genuine<br>Quality</div></div>
    </div>

    <!-- ACCORDION -->
    <div class="jgz-accordion">
      <div class="jgz-accordion-item open">
        <button class="jgz-accordion-header" onclick="jgzToggle(this)">Description <span class="jgz-accordion-icon">+</span></button>
        <div class="jgz-accordion-body">{{ product.description }}</div>
      </div>
      <div class="jgz-accordion-item">
        <button class="jgz-accordion-header" onclick="jgzToggle(this)">Fabric &amp; Care <span class="jgz-accordion-icon">+</span></button>
        <div class="jgz-accordion-body"><ul>
          <li>100% Premium Ring-Spun Cotton</li>
          <li>180 GSM — lightweight summer weight</li>
          <li>Stretchable &amp; breathable fabric</li>
          <li>Machine wash cold, tumble dry low</li>
          <li>Do not bleach or iron on print</li>
        </ul></div>
      </div>
      <div class="jgz-accordion-item">
        <button class="jgz-accordion-header" onclick="jgzToggle(this)">Shipping &amp; Returns <span class="jgz-accordion-icon">+</span></button>
        <div class="jgz-accordion-body"><ul>
          <li>Standard delivery: 3–5 business days</li>
          <li>Express: 1–2 business days</li>
          <li>Free shipping on orders PKR 2,500+</li>
          <li>Cash on Delivery available nationwide</li>
          <li>Free returns within 30 days</li>
        </ul></div>
      </div>
      <div class="jgz-accordion-item">
        <button class="jgz-accordion-header" onclick="jgzToggle(this)">Size &amp; Fit <span class="jgz-accordion-icon">+</span></button>
        <div class="jgz-accordion-body"><ul>
          <li>Smart relaxed fit</li>
          <li>Model is 6'0" wearing size M</li>
          <li>Chest: S=36" · M=38" · L=40" · XL=42"</li>
          <li>Length: S=27" · M=28" · L=29" · XL=30"</li>
        </ul></div>
      </div>
    </div>

  </div>
</div>


<!-- STICKY MOBILE CTA -->
<div class="jgz-sticky-cta">
  <div class="jgz-sticky-cta-info">
    <div class="jgz-sticky-cta-name">{{ product.title | truncate: 36 }}</div>
    <div class="jgz-sticky-cta-price">{{ product.price | money }}</div>
  </div>
  <button class="jgz-sticky-cta-btn" onclick="document.getElementById('jgzAtcBtn').click()">Add to Bag</button>
</div>

<script>
  var jgzCurrentIdx = 0;
  var jgzThumbs = document.querySelectorAll('.jgz-gallery-thumb');
  var jgzMainImg = document.getElementById('jgzMainImg');

  window.jgzThumb = function(el, src) {
    jgzThumbs.forEach(function(t){ t.classList.remove('active'); });
    el.classList.add('active');
    jgzCurrentIdx = parseInt(el.dataset.idx || 0);
    if (jgzMainImg) jgzMainImg.src = src;
  };

  window.jgzNavImg = function(dir) {
    if (!jgzThumbs.length) return;
    jgzCurrentIdx = (jgzCurrentIdx + dir + jgzThumbs.length) % jgzThumbs.length;
    jgzThumbs[jgzCurrentIdx].click();
  };

  var jgzQtyVal = 1;
  window.jgzQty = function(d) {
    jgzQtyVal = Math.max(1, jgzQtyVal + d);
    document.getElementById('jgzQtyDisplay').textContent = jgzQtyVal;
    document.getElementById('jgzQtyHidden').value = jgzQtyVal;
  };

  var jgzOpts = {};
  {%- for option in product.options_with_values -%}
    jgzOpts[{{ option.position }}] = '{{ option.selected_value | escape }}';
  {%- endfor -%}
  var jgzVariants = {{ product.variants | json }};

  function jgzUpdateVariant() {
    var match = jgzVariants.find(function(v) {
      return Object.keys(jgzOpts).every(function(p) { return v['option' + p] === jgzOpts[p]; });
    });
    if (match) {
      document.getElementById('jgzVariantId').value = match.id;
      var priceEl = document.getElementById('jgzPrice');
      if (priceEl) priceEl.textContent = 'Rs.' + (match.price / 100).toFixed(0).replace(/\B(?=(\d{3})+(?!\d))/g, ',');
    }
  }

  window.jgzSelectColor = function(el, pos, val) {
    el.parentElement.querySelectorAll('.jgz-color-opt').forEach(function(c){ c.classList.remove('active'); });
    el.classList.add('active');
    var nameEl = document.getElementById('jgzColorName');
    if (nameEl) nameEl.textContent = val;
    jgzOpts[pos] = val;
    jgzUpdateVariant();
  };

  window.jgzSelectSize = function(el, pos, val) {
    if (el.classList.contains('soldout')) return;
    el.parentElement.querySelectorAll('.jgz-size-opt').forEach(function(s){ s.classList.remove('active'); });
    el.classList.add('active');
    jgzOpts[pos] = val;
    jgzUpdateVariant();
  };

  window.jgzToggle = function(btn) {
    var item = btn.parentElement;
    item.classList.toggle('open');
  };

  var form = document.getElementById('jgz-product-form');
  if (form) {
    form.addEventListener('submit', function() {
      var btn = document.getElementById('jgzAtcBtn');
      if (!btn) return;
      setTimeout(function() {
        btn.textContent = '✓ Added!';
        btn.classList.add('added');
        setTimeout(function() {
          btn.textContent = 'Add to Bag';
          btn.classList.remove('added');
        }, 2000);
      }, 200);
    });
  }
</script>


{% schema %}
{
  "name": "t:names.product_information",
  "blocks": [
    {
      "type": "@app"
    }
  ],
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "header",
      "content": "t:content.layout"
    },
    {
      "type": "select",
      "id": "content_width",
      "label": "t:settings.width",
      "options": [
        {
          "value": "content-center-aligned",
          "label": "t:options.page"
        },
        {
          "value": "content-full-width",
          "label": "t:options.full"
        }
      ],
      "default": "content-center-aligned"
    },
    {
      "type": "select",
      "id": "desktop_media_position",
      "label": "t:settings.media_position",
      "options": [
        {
          "value": "left",
          "label": "t:options.left"
        },
        {
          "value": "right",
          "label": "t:options.right"
        }
      ],
      "default": "left"
    },
    {
      "type": "checkbox",
      "id": "equal_columns",
      "label": "t:settings.equal_columns",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "limit_details_width",
      "label": "t:settings.limit_product_details_width",
      "default": false,
      "visible_if": "{{ section.settings.equal_columns }}"
    },
    {
      "type": "range",
      "id": "gap",
      "label": "t:settings.gap",
      "min": 0,
      "max": 48,
      "step": 4,
      "unit": "px",
      "default": 16
    },
    {
      "type": "checkbox",
      "id": "enable_sticky_add_to_cart",
      "label": "t:settings.enable_sticky_add_to_cart",
      "default": true
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:settings.color_scheme",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "t:content.padding"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "t:settings.top",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "t:settings.bottom",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 0
    }
  ],
  "presets": []
}
{% endschema %}
