<style>
  .jgz-categories {
    background: var(--jgz-black);
    padding: 80px var(--jgz-px);
  }

  .jgz-categories__header {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    margin-bottom: 32px;
  }

  .jgz-categories__grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 24px;
  }

  .jgz-cat-card {
    position: relative;
    overflow: hidden;
    cursor: pointer;
    aspect-ratio: 3 / 4;
    background: var(--jgz-card-bg);
  }

  .jgz-cat-card img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.5s ease;
  }
  .jgz-cat-card:hover img { transform: scale(1.04); }

  .jgz-cat-card__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(10,10,10,0.75) 0%, transparent 55%);
  }

  .jgz-cat-card__arrow {
    position: absolute;
    top: 16px;
    right: 16px;
    width: 32px;
    height: 32px;
    background: var(--jgz-gold);
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    transition: opacity 0.25s;
    color: #0a0a0a;
  }
  .jgz-cat-card:hover .jgz-cat-card__arrow { opacity: 1; }

  .jgz-cat-card__info {
    position: absolute;
    bottom: 24px;
    left: 20px;
    right: 20px;
  }

  .jgz-cat-card__name {
    font-family: var(--jgz-heading);
    font-size: 24px;
    font-weight: 300;
    color: var(--jgz-off-white);
    margin: 0 0 4px;
    line-height: 1.1;
  }

  .jgz-cat-card__count {
    font-family: var(--jgz-body);
    font-size: 10px;
    font-weight: 500;
    letter-spacing: 0.15em;
    color: var(--jgz-off-white);
    opacity: 0.5;
    text-transform: uppercase;
  }

  .jgz-cat-card__placeholder {
    width: 100%;
    height: 100%;
    background: var(--jgz-card-bg);
    display: flex;
    align-items: center;
    justify-content: center;
    color: rgba(245,244,240,0.1);
    font-size: 11px;
    font-family: var(--jgz-body);
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  @media (max-width: 768px) {
    .jgz-categories {
      padding: 48px var(--jgz-px-m);
    }
    .jgz-categories__grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 12px;
    }
  }
</style>

<section class="jgz-categories">
  <div class="jgz-categories__header">
    <div>
      <p class="jgz-section-label">{{ section.settings.section_label }}</p>
      <h2 class="jgz-section-title" style="font-size: 42px;">{{ section.settings.section_title }}</h2>
    </div>
  </div>

  <div class="jgz-categories__grid">
    {%- for block in section.blocks -%}
      <a href="{{ block.settings.link }}" class="jgz-cat-card" {{ block.shopify_attributes }}>
        {%- if block.settings.image != blank -%}
          <img src="{{ block.settings.image | image_url: width: 600 }}" alt="{{ block.settings.name }}" width="600" loading="lazy">
        {%- else -%}
          <div class="jgz-cat-card__placeholder">{{ block.settings.name }}</div>
        {%- endif -%}
        <div class="jgz-cat-card__overlay"></div>
        <div class="jgz-cat-card__arrow">
          <svg width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M3 11L11 3M11 3H5M11 3V9" stroke="currentColor" stroke-width="1.5"/></svg>
        </div>
        <div class="jgz-cat-card__info">
          <h3 class="jgz-cat-card__name">{{ block.settings.name }}</h3>
          <span class="jgz-cat-card__count">{{ block.settings.count }}</span>
        </div>
      </a>
    {%- endfor -%}
  </div>
</section>

{% schema %}
{
  "name": "JIGERZ Category Grid",
  "settings": [
    { "type": "text", "id": "section_label", "label": "Section label", "default": "Shop by Category" },
    { "type": "text", "id": "section_title", "label": "Section title", "default": "Browse Our Range" }
  ],
  "blocks": [
    {
      "type": "category",
      "name": "Category",
      "settings": [
        { "type": "text", "id": "name", "label": "Category name", "default": "T-Shirts" },
        { "type": "text", "id": "count", "label": "Count label", "default": "24 Styles" },
        { "type": "url", "id": "link", "label": "Link" },
        { "type": "image_picker", "id": "image", "label": "Category image" }
      ]
    }
  ],
  "presets": [
    {
      "name": "JIGERZ Category Grid",
      "blocks": [
        { "type": "category", "settings": { "name": "T-Shirts", "count": "24 Styles" } },
        { "type": "category", "settings": { "name": "Polo", "count": "10 Styles" } },
        { "type": "category", "settings": { "name": "Oversized", "count": "14 Styles" } },
        { "type": "category", "settings": { "name": "Accessories", "count": "8 Styles" } }
      ]
    }
  ]
}
{% endschema %}
