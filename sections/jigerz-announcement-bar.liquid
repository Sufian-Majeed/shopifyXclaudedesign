<style>
  .jgz-promo-bar {
    background: var(--jgz-gold);
    padding: 10px var(--jgz-px);
    text-align: center;
  }
  .jgz-promo-bar p {
    font-family: var(--jgz-body);
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: #0a0a0a;
    margin: 0;
  }
  @media (max-width: 768px) {
    .jgz-promo-bar { padding: 10px var(--jgz-px-m); }
  }
</style>

<div class="jgz-promo-bar">
  <p>{{ section.settings.promo_text }}</p>
</div>

{% schema %}
{
  "name": "JIGERZ Promo Bar",
  "settings": [
    {
      "type": "text",
      "id": "promo_text",
      "label": "Promo text",
      "default": "FREE DELIVERY ON ORDERS OVER PKR 2,500 · LIMITED SUMMER SALE — USE CODE JIGERZ10"
    }
  ],
  "presets": [{ "name": "JIGERZ Promo Bar" }]
}
{% endschema %}
