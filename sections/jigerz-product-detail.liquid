      "default": "Model is 6'0\" wearing size M\nRegular fit — true to size\nChest: S=36\", M=38\", L=40\", XL=42\", XXL=44\"\nIf between sizes, size up for a relaxed fit"
    }
  ],
  "presets": [{ "name": "JIGERZ Product Detail" }]
}
{% endschema %}
