  "settings": [
    {
      "type": "textarea",
      "id": "fabric_care",
      "label": "Fabric & Care text",
      "default": "100% Ring-Spun Cotton\nMachine wash cold, gentle cycle\nDo not bleach\nTumble dry low\nCool iron if needed"
    },
    {
      "type": "textarea",
      "id": "shipping_returns",
