<style>
  * { box-sizing: border-box; }

  .jgz-breadcrumb { padding: 18px 60px; font-size: 10px; letter-spacing: 0.2em; text-transform: uppercase; opacity: 0.35; border-bottom: 1px solid var(--color-border); font-family: 'Barlow', system-ui, sans-serif; }
  .jgz-breadcrumb a { color: var(--color-foreground); text-decoration: none; }
  .jgz-breadcrumb a:hover { color: var(--color-primary); }

  .jgz-pdp { display: grid; grid-template-columns: 1fr 1fr; min-height: 90vh; background: var(--color-background); }

  .jgz-gallery { display: grid; grid-template-columns: 76px 1fr; gap: 3px; padding: 40px 0 40px 60px; position: sticky; top: 72px; height: calc(100vh - 72px); }
  .jgz-gallery-thumbs { display: flex; flex-direction: column; gap: 3px; overflow-y: auto; }
  .jgz-gallery-thumb { aspect-ratio: 3/4; background: #141414; cursor: pointer; border: 2px solid transparent; transition: border-color 0.2s; overflow: hidden; flex-shrink: 0; }
  .jgz-gallery-thumb img { width: 100%; height: 100%; object-fit: cover; }
  .jgz-gallery-thumb.active { border-color: #b8975a; }
  .jgz-gallery-thumb:hover { border-color: rgba(184,151,90,0.5); }
  .jgz-gallery-main { background: #141414; position: relative; overflow: hidden; }
  .jgz-gallery-main img { width: 100%; height: 100%; object-fit: cover; display: block; }
  .jgz-gallery-zoom { position: absolute; bottom: 20px; right: 20px; font-size: 10px; letter-spacing: 0.15em; text-transform: uppercase; opacity: 0.3; cursor: pointer; color: var(--color-foreground); font-family: 'Barlow', system-ui, sans-serif; }
  .jgz-gallery-nav { position: absolute; top: 50%; transform: translateY(-50%); display: flex; justify-content: space-between; width: 100%; padding: 0 16px; pointer-events: none; }
  .jgz-gallery-nav-btn { width: 40px; height: 40px; border: 1px solid var(--color-border); background: rgb(var(--color-background-rgb) / 0.7); color: var(--color-foreground); display: flex; align-items: center; justify-content: center; cursor: pointer; pointer-events: all; font-size: 16px; transition: all 0.2s; }
  .jgz-gallery-nav-btn:hover { border-color: var(--color-primary); color: var(--color-primary); }

  .jgz-product-info { padding: 40px 60px 100px 48px; overflow-y: auto; background: var(--color-background); }

  .jgz-product-badge-row { display: flex; gap: 8px; margin-bottom: 16px; flex-wrap: wrap; }
  .jgz-p-badge { font-size: 9px; font-weight: 600; letter-spacing: 0.15em; text-transform: uppercase; padding: 5px 12px; border: 1px solid var(--color-primary); color: var(--color-primary); font-family: 'Barlow', system-ui, sans-serif; }
  .jgz-p-badge.filled { background: var(--color-primary); color: var(--color-background); }
  .jgz-p-badge.cod { background: #1a3a1a; color: #4caf50; border-color: #4caf50; }

  .jgz-product-title { font-family: 'Cormorant Garamond', Georgia, serif; font-size: 44px; font-weight: 300; line-height: 1.05; margin-bottom: 6px; color: var(--color-foreground-heading); }
  .jgz-product-sku { font-size: 10px; opacity: 0.3; letter-spacing: 0.2em; margin-bottom: 16px; color: var(--color-foreground); font-family: 'Barlow', system-ui, sans-serif; text-transform: uppercase; }

  .jgz-rating-row { display: flex; align-items: center; gap: 10px; margin-bottom: 20px; padding-bottom: 20px; border-bottom: 1px solid var(--color-border); flex-wrap: wrap; }
  .jgz-stars { color: var(--color-primary); font-size: 13px; letter-spacing: 2px; }
  .jgz-rating-count { font-size: 11px; opacity: 0.4; color: var(--color-foreground); font-family: 'Barlow', system-ui, sans-serif; }
  .jgz-rating-link { font-size: 11px; color: var(--color-primary); text-decoration: none; opacity: 0.7; font-family: 'Barlow', system-ui, sans-serif; }
  .jgz-rating-link:hover { opacity: 1; border-bottom: 1px solid var(--color-primary); }

  .jgz-compare-price-box { background: rgb(var(--color-primary-rgb) / 0.08); border: 1px solid rgb(var(--color-primary-rgb) / 0.25); padding: 16px 20px; margin-bottom: 20px; display: flex; align-items: center; justify-content: space-between; flex-wrap: wrap; gap: 8px; }
  .jgz-compare-label { font-size: 10px; letter-spacing: 0.2em; text-transform: uppercase; opacity: 0.5; margin-bottom: 4px; color: var(--color-foreground); font-family: 'Barlow', system-ui, sans-serif; }
  .jgz-compare-prices { display: flex; align-items: baseline; gap: 12px; }
  .jgz-compare-now { font-family: 'Cormorant Garamond', Georgia, serif; font-size: 32px; font-weight: 600; color: var(--color-primary); }
  .jgz-compare-was { font-size: 16px; opacity: 0.4; text-decoration: line-through; color: var(--color-foreground); }
  .jgz-compare-save-pill { background: var(--color-primary); color: var(--color-background); font-size: 10px; font-weight: 700; letter-spacing: 0.1em; padding: 6px 14px; font-family: 'Barlow', system-ui, sans-serif; }

  .jgz-stock-indicator { display: flex; align-items: center; gap: 8px; margin-bottom: 20px; font-size: 12px; font-family: 'Barlow', system-ui, sans-serif; }
  .jgz-stock-dot { width: 8px; height: 8px; border-radius: 50%; background: #e85d04; animation: jgzPulse 1.5s infinite; flex-shrink: 0; }
  @keyframes jgzPulse { 0%,100%{opacity:1;}50%{opacity:0.4;} }
  .jgz-stock-text { color: #e85d04; font-weight: 500; letter-spacing: 0.05em; }
  .jgz-stock-sub { opacity: 0.45; font-size: 11px; color: var(--color-foreground); }

  .jgz-product-bullets { margin-bottom: 24px; display: flex; flex-direction: column; gap: 8px; }
  .jgz-bullet-item { display: flex; align-items: center; gap: 10px; font-size: 12px; opacity: 0.75; color: var(--color-foreground); font-family: 'Barlow', system-ui, sans-serif; }
  .jgz-bullet-check { color: var(--color-primary); font-size: 14px; flex-shrink: 0; }

  .jgz-option-section { margin-bottom: 24px; }
  .jgz-option-label { font-size: 10px; letter-spacing: 0.2em; text-transform: uppercase; opacity: 0.5; margin-bottom: 10px; display: flex; justify-content: space-between; align-items: center; color: var(--color-foreground); font-family: 'Barlow', system-ui, sans-serif; }
  .jgz-option-selected { color: var(--color-primary); opacity: 1; font-weight: 500; }
  .jgz-color-options { display: flex; gap: 10px; }
  .jgz-color-opt { width: 30px; height: 30px; border-radius: 50%; cursor: pointer; border: 2px solid transparent; transition: all 0.2s; outline: 1px solid var(--color-border); }
  .jgz-color-opt.active { border-color: var(--color-primary); outline-color: var(--color-primary); }
  .jgz-color-opt:hover { transform: scale(1.1); }

  .jgz-size-grid { display: flex; flex-wrap: wrap; gap: 8px; }
  .jgz-size-opt { min-width: 50px; padding: 9px 14px; border: 1px solid var(--color-border); font-size: 12px; letter-spacing: 0.1em; text-align: center; cursor: pointer; transition: all 0.2s; opacity: 0.55; background: none; color: var(--color-foreground); font-family: 'Barlow', system-ui, sans-serif; }
  .jgz-size-opt:hover { border-color: rgb(var(--color-foreground-rgb) / 0.3); opacity: 1; }
  .jgz-size-opt.active { border-color: var(--color-primary); color: var(--color-primary); opacity: 1; }
  .jgz-size-opt.soldout { opacity: 0.2; text-decoration: line-through; cursor: not-allowed; }
  .jgz-size-guide-link { font-size: 10px; color: var(--color-primary); text-decoration: none; letter-spacing: 0.1em; font-family: 'Barlow', system-ui, sans-serif; }

  .jgz-delivery-line { display: flex; align-items: center; gap: 10px; background: rgb(var(--color-foreground-rgb) / 0.03); border: 1px solid var(--color-border); padding: 12px 16px; margin-bottom: 20px; font-size: 12px; opacity: 0.75; color: var(--color-foreground); font-family: 'Barlow', system-ui, sans-serif; }

  .jgz-add-row { display: grid; grid-template-columns: 110px 1fr; gap: 10px; margin-bottom: 12px; }
  .jgz-qty-control { display: flex; align-items: center; border: 1px solid var(--color-border); background: var(--color-input-background); }
  .jgz-qty-btn { width: 34px; height: 48px; background: none; border: none; color: var(--color-foreground); font-size: 18px; cursor: pointer; opacity: 0.5; transition: opacity 0.2s; font-family: 'Barlow', system-ui, sans-serif; }
  .jgz-qty-btn:hover { opacity: 1; }
  .jgz-qty-val { flex: 1; text-align: center; font-size: 14px; color: var(--color-foreground); }
  .jgz-add-to-cart { background: var(--color-primary); color: var(--color-background); border: none; font-family: 'Barlow', system-ui, sans-serif; font-size: 12px; font-weight: 600; letter-spacing: 0.2em; text-transform: uppercase; cursor: pointer; transition: all 0.2s; height: 48px; }
  .jgz-add-to-cart:hover { background: var(--color-foreground); }
  .jgz-add-to-cart.added { background: #2e7d32 !important; color: white !important; }
  .jgz-buy-now { width: 100%; background: none; border: 1px solid var(--color-border); color: var(--color-foreground); font-family: 'Barlow', system-ui, sans-serif; font-size: 12px; letter-spacing: 0.2em; text-transform: uppercase; cursor: pointer; height: 48px; transition: all 0.2s; margin-bottom: 20px; }
  .jgz-buy-now:hover { border-color: var(--color-primary); color: var(--color-primary); }

  .jgz-trust-badges { display: grid; grid-template-columns: repeat(4, 1fr); gap: 12px; padding: 20px 0; border-top: 1px solid var(--color-border); border-bottom: 1px solid var(--color-border); margin-bottom: 28px; }
  .jgz-trust-badge { text-align: center; }
  .jgz-trust-badge-icon { font-size: 18px; margin-bottom: 5px; opacity: 0.6; }
  .jgz-trust-badge-text { font-size: 9px; letter-spacing: 0.08em; text-transform: uppercase; opacity: 0.45; line-height: 1.5; color: var(--color-foreground); font-family: 'Barlow', system-ui, sans-serif; }

  .jgz-accordion { border-top: 1px solid var(--color-border); }
  .jgz-accordion-item { border-bottom: 1px solid var(--color-border); }
  .jgz-accordion-header { width: 100%; background: none; border: none; color: var(--color-foreground); font-family: 'Barlow', system-ui, sans-serif; font-size: 11px; letter-spacing: 0.2em; text-transform: uppercase; padding: 16px 0; display: flex; justify-content: space-between; align-items: center; cursor: pointer; opacity: 0.7; transition: opacity 0.2s; }
  .jgz-accordion-header:hover { opacity: 1; }
  .jgz-accordion-icon { font-size: 18px; transition: transform 0.3s; }
  .jgz-accordion-item.open .jgz-accordion-icon { transform: rotate(45deg); }
  .jgz-accordion-body { display: none; padding-bottom: 18px; font-size: 13px; line-height: 1.8; opacity: 0.55; color: var(--color-foreground); font-family: 'Barlow', system-ui, sans-serif; }
  .jgz-accordion-item.open .jgz-accordion-body { display: block; }
  .jgz-accordion-body ul { list-style: none; display: flex; flex-direction: column; gap: 6px; padding: 0; }
  .jgz-accordion-body li::before { content: '— '; color: var(--color-primary); }

  .jgz-related { padding: 72px 60px; border-top: 1px solid var(--color-border); background: var(--color-background); }
  .jgz-related-label { font-size: 10px; letter-spacing: 0.3em; text-transform: uppercase; color: var(--color-primary); margin-bottom: 12px; font-family: 'Barlow', system-ui, sans-serif; }
  .jgz-related-title { font-family: 'Cormorant Garamond', Georgia, serif; font-size: 38px; font-weight: 300; margin-bottom: 40px; color: var(--color-foreground-heading); }
  .jgz-related-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 20px; }
  .jgz-r-card { cursor: pointer; text-decoration: none; display: block; }
  .jgz-r-img { aspect-ratio: 3/4; background: var(--color-input-background); margin-bottom: 12px; overflow: hidden; }
  .jgz-r-img img { width: 100%; height: 100%; object-fit: cover; transition: transform 0.4s; }
  .jgz-r-card:hover .jgz-r-img img { transform: scale(1.04); }
  .jgz-r-name { font-size: 13px; margin-bottom: 5px; color: var(--color-foreground); font-family: 'Barlow', system-ui, sans-serif; }
  .jgz-r-prices { display: flex; gap: 8px; align-items: baseline; }
  .jgz-r-price { font-family: 'Cormorant Garamond', Georgia, serif; font-size: 17px; color: var(--color-primary); }
  .jgz-r-price-old { font-size: 12px; opacity: 0.35; text-decoration: line-through; color: var(--color-foreground); }

  .jgz-sticky-cta { display: none; position: fixed; bottom: 0; left: 0; right: 0; z-index: 50; background: rgb(var(--color-background-rgb) / 0.97); border-top: 1px solid var(--color-border); padding: 12px 20px; gap: 12px; align-items: center; backdrop-filter: blur(10px); }
  .jgz-sticky-cta-info { flex: 1; }
  .jgz-sticky-cta-name { font-size: 13px; font-weight: 400; color: var(--color-foreground); font-family: 'Barlow', system-ui, sans-serif; }
  .jgz-sticky-cta-price { font-family: 'Cormorant Garamond', Georgia, serif; font-size: 18px; color: var(--color-primary); }
  .jgz-sticky-cta-btn { background: var(--color-primary); color: var(--color-background); border: none; padding: 12px 28px; font-family: 'Barlow', system-ui, sans-serif; font-size: 11px; font-weight: 600; letter-spacing: 0.15em; text-transform: uppercase; cursor: pointer; }

  @media (max-width: 768px) {
    .jgz-breadcrumb { padding: 12px 20px; }
    .jgz-pdp { grid-template-columns: 1fr; }
    .jgz-gallery { grid-template-columns: 1fr; padding: 0; position: relative; top: auto; height: auto; }
    .jgz-gallery-thumbs { flex-direction: row; padding: 8px 16px; gap: 6px; overflow-x: auto; overflow-y: visible; }
    .jgz-gallery-thumb { width: 56px; height: 75px; aspect-ratio: unset; flex-shrink: 0; }
    .jgz-gallery-main { height: 400px; }
    .jgz-product-info { padding: 24px 20px 120px; }
    .jgz-product-title { font-size: 34px; }
    .jgz-trust-badges { grid-template-columns: repeat(2, 1fr); }
    .jgz-add-row { grid-template-columns: 90px 1fr; }
    .jgz-related { padding: 48px 20px; }
    .jgz-related-title { font-size: 28px; margin-bottom: 24px; }
    .jgz-related-grid { grid-template-columns: repeat(2, 1fr); gap: 12px; }
    .jgz-sticky-cta { display: flex; }
  }
</style>

{%- assign current_variant = product.selected_or_first_available_variant -%}
{%- assign savings_percent = 0 -%}
{%- if product.compare_at_price > product.price -%}
  {%- assign savings = product.compare_at_price | minus: product.price -%}
  {%- assign savings_percent = savings | times: 100 | divided_by: product.compare_at_price -%}
{%- endif -%}

<div class="color-{{ section.settings.color_scheme }}">
<!-- Breadcrumb -->
<div class="jgz-breadcrumb">
  <a href="/">Home</a> &nbsp;/&nbsp;
  {%- if product.collections.first -%}
    <a href="{{ product.collections.first.url }}">{{ product.collections.first.title }}</a> &nbsp;/&nbsp;
  {%- endif -%}
  {{ product.title }}
</div>

<div class="jgz-pdp">

  <!-- GALLERY -->
  <div class="jgz-gallery">
    <div class="jgz-gallery-thumbs">
      {%- for image in product.images limit: 8 -%}
        <div class="jgz-gallery-thumb {% if forloop.first %}active{% endif %}"
             onclick="jgzThumb(this, '{{ image | image_url: width: 1200 }}')"
             data-idx="{{ forloop.index0 }}">
          <img src="{{ image | image_url: width: 160 }}" alt="{{ product.title }}" loading="lazy">
        </div>
      {%- else -%}
        <div class="jgz-gallery-thumb active" style="background:#141414;"></div>
      {%- endfor -%}
    </div>
    <div class="jgz-gallery-main">
      {%- if product.featured_image -%}
        <img id="jgzMainImg" src="{{ product.featured_image | image_url: width: 1200 }}" alt="{{ product.title }}" loading="eager">
      {%- else -%}
        <div style="width:100%;height:100%;display:flex;align-items:center;justify-content:center;color:rgba(255,255,255,0.15);font-family:'Barlow',system-ui,sans-serif;font-size:11px;letter-spacing:0.1em;">No Image</div>
      {%- endif -%}
      <div class="jgz-gallery-zoom">+ Zoom</div>
      <div class="jgz-gallery-nav">
        <button class="jgz-gallery-nav-btn" onclick="jgzNavImg(-1)">‹</button>
        <button class="jgz-gallery-nav-btn" onclick="jgzNavImg(1)">›</button>
      </div>
    </div>
  </div>

  <!-- PRODUCT INFO -->
  <div class="jgz-product-info">

    <div class="jgz-product-badge-row">
      {%- if product.tags contains 'new-arrival' -%}
        <span class="jgz-p-badge filled">New Arrival</span>
      {%- endif -%}
      {%- if current_variant.available -%}
        <span class="jgz-p-badge">In Stock</span>
      {%- endif -%}
      <span class="jgz-p-badge cod">💵 Cash on Delivery</span>
    </div>

    <h1 class="jgz-product-title">{{ product.title }}</h1>
    {%- if current_variant.sku != blank -%}
      <div class="jgz-product-sku">SKU: {{ current_variant.sku }}</div>
    {%- endif -%}

    <div class="jgz-rating-row">
      <div class="jgz-stars">★★★★★</div>
      <span class="jgz-rating-count">4.9 / 5</span>
      <a href="#reviews" class="jgz-rating-link">48 Reviews</a>
    </div>

    <!-- PRICE BOX -->
    <div class="jgz-compare-price-box">
      <div>
        <div class="jgz-compare-label">Price</div>
        <div class="jgz-compare-prices">
          <span class="jgz-compare-now" id="jgzPrice">{{ current_variant.price | money }}</span>
          {%- if product.compare_at_price > product.price -%}
            <span class="jgz-compare-was">{{ product.compare_at_price | money }}</span>
          {%- endif -%}
        </div>
      </div>
      {%- if savings_percent > 0 -%}
        <span class="jgz-compare-save-pill">SAVE {{ savings_percent }}%</span>
      {%- endif -%}
    </div>

    {%- if current_variant.inventory_management == 'shopify' and current_variant.inventory_quantity > 0 and current_variant.inventory_quantity < 10 -%}
      <div class="jgz-stock-indicator">
        <div class="jgz-stock-dot"></div>
        <span class="jgz-stock-text">Only {{ current_variant.inventory_quantity }} pieces left!</span>
        <span class="jgz-stock-sub">— Order soon</span>
      </div>
    {%- endif -%}

    <div class="jgz-product-bullets">
      <div class="jgz-bullet-item"><span class="jgz-bullet-check">✓</span> Premium Imported Fabric — 100% Ring-Spun Cotton</div>
      <div class="jgz-bullet-item"><span class="jgz-bullet-check">✓</span> Stretchable &amp; Breathable — Perfect for Summer</div>
      <div class="jgz-bullet-item"><span class="jgz-bullet-check">✓</span> Smart Fit Design — Modern Relaxed Silhouette</div>
    </div>

    {%- form 'product', product, id: 'jgz-product-form' -%}
      <input type="hidden" name="id" id="jgzVariantId" value="{{ current_variant.id }}">
      <input type="hidden" name="quantity" id="jgzQtyHidden" value="1">

      {%- for option in product.options_with_values -%}
        <div class="jgz-option-section">
          {%- if option.name == 'Color' or option.name == 'Colour' -%}
            <div class="jgz-option-label">
              {{ option.name }}
              <span class="jgz-option-selected" id="jgzColorName">{{ option.selected_value }}</span>
            </div>
            <div class="jgz-color-options">
              {%- for value in option.values -%}
                <div class="jgz-color-opt {% if option.selected_value == value %}active{% endif %}"
                     style="background: {{ value | downcase }};"
                     title="{{ value }}"
                     onclick="jgzSelectColor(this, {{ option.position }}, '{{ value }}')">
                </div>
              {%- endfor -%}
            </div>
          {%- else -%}
            <div class="jgz-option-label">
              {{ option.name }}
              {%- if option.name == 'Size' -%}
                <a href="#" class="jgz-size-guide-link">Size Guide →</a>
              {%- endif -%}
            </div>
            <div class="jgz-size-grid">
              {%- for value in option.values -%}
                <div class="jgz-size-opt {% if option.selected_value == value %}active{% endif %}"
                     onclick="jgzSelectSize(this, {{ option.position }}, '{{ value }}')">
                  {{ value }}
                </div>
              {%- endfor -%}
            </div>
          {%- endif -%}
        </div>
      {%- endfor -%}

      <div class="jgz-delivery-line">
        <span>🚚</span>
        <span>Order now &amp; get delivery in <strong>3–5 business days</strong> · Free on orders PKR 2,500+</span>
      </div>

      <div class="jgz-add-row">
        <div class="jgz-qty-control">
          <button type="button" class="jgz-qty-btn" onclick="jgzQty(-1)">−</button>
          <span class="jgz-qty-val" id="jgzQtyDisplay">1</span>
          <button type="button" class="jgz-qty-btn" onclick="jgzQty(1)">+</button>
        </div>
        <button type="submit" name="add" class="jgz-add-to-cart" id="jgzAtcBtn">
          {%- if current_variant.available -%}Add to Bag{%- else -%}Sold Out{%- endif -%}
        </button>
      </div>

      <button type="button" id="jgzBuyNow" class="jgz-buy-now" onclick="jgzBuyNow()">Buy Now — {{ current_variant.price | money }}</button>

    {%- endform -%}

    <div class="jgz-trust-badges">
      <div class="jgz-trust-badge"><div class="jgz-trust-badge-icon">🚚</div><div class="jgz-trust-badge-text">Free<br>Shipping</div></div>
      <div class="jgz-trust-badge"><div class="jgz-trust-badge-icon">💵</div><div class="jgz-trust-badge-text">Cash on<br>Delivery</div></div>
      <div class="jgz-trust-badge"><div class="jgz-trust-badge-icon">↩</div><div class="jgz-trust-badge-text">30-Day<br>Returns</div></div>
      <div class="jgz-trust-badge"><div class="jgz-trust-badge-icon">✓</div><div class="jgz-trust-badge-text">Genuine<br>Quality</div></div>
    </div>

    <div class="jgz-accordion">
      <div class="jgz-accordion-item open">
        <button class="jgz-accordion-header" onclick="jgzToggle(this)">Description <span class="jgz-accordion-icon">+</span></button>
        <div class="jgz-accordion-body">{{ product.description }}</div>
      </div>
      <div class="jgz-accordion-item">
        <button class="jgz-accordion-header" onclick="jgzToggle(this)">Fabric &amp; Care <span class="jgz-accordion-icon">+</span></button>
        <div class="jgz-accordion-body"><ul>
          <li>100% Premium Ring-Spun Cotton</li>
          <li>180 GSM — lightweight summer weight</li>
          <li>Stretchable &amp; breathable fabric</li>
          <li>Machine wash cold, tumble dry low</li>
          <li>Do not bleach or iron on print</li>
        </ul></div>
      </div>
      <div class="jgz-accordion-item">
        <button class="jgz-accordion-header" onclick="jgzToggle(this)">Shipping &amp; Returns <span class="jgz-accordion-icon">+</span></button>
        <div class="jgz-accordion-body"><ul>
          <li>Standard delivery: 3–5 business days</li>
          <li>Express: 1–2 business days</li>
          <li>Free shipping on orders PKR 2,500+</li>
          <li>Cash on Delivery available nationwide</li>
          <li>Free returns within 30 days</li>
        </ul></div>
      </div>
      <div class="jgz-accordion-item">
        <button class="jgz-accordion-header" onclick="jgzToggle(this)">Size &amp; Fit <span class="jgz-accordion-icon">+</span></button>
        <div class="jgz-accordion-body"><ul>
          <li>Smart relaxed fit</li>
          <li>Model is 6'0" wearing size M</li>
          <li>Chest: S=36" · M=38" · L=40" · XL=42"</li>
          <li>Length: S=27" · M=28" · L=29" · XL=30"</li>
        </ul></div>
      </div>
    </div>

  </div>
</div>

{%- assign related_collection = product.collections.first -%}
{%- if related_collection != blank -%}
  <div class="jgz-related">
    <div class="jgz-related-label">You May Also Like</div>
    <div class="jgz-related-title">Complete the Look</div>
    <div class="jgz-related-grid">
      {%- assign shown = 0 -%}
      {%- for rel in related_collection.products -%}
        {%- if rel.id != product.id and shown < 4 -%}
          {%- assign shown = shown | plus: 1 -%}
          <a href="{{ rel.url }}" class="jgz-r-card">
            <div class="jgz-r-img">
              {%- if rel.featured_image -%}
                <img src="{{ rel.featured_image | image_url: width: 600 }}" alt="{{ rel.title }}" loading="lazy">
              {%- endif -%}
            </div>
            <div class="jgz-r-name">{{ rel.title }}</div>
            <div class="jgz-r-prices">
              <span class="jgz-r-price">{{ rel.price | money }}</span>
              {%- if rel.compare_at_price > rel.price -%}
                <span class="jgz-r-price-old">{{ rel.compare_at_price | money }}</span>
              {%- endif -%}
            </div>
          </a>
        {%- endif -%}
      {%- endfor -%}
    </div>
  </div>
{%- endif -%}

<div class="jgz-sticky-cta">
  <div class="jgz-sticky-cta-info">
    <div class="jgz-sticky-cta-name">{{ product.title | truncate: 36 }}</div>
    <div class="jgz-sticky-cta-price">{{ product.price | money }}</div>
  </div>
  <button class="jgz-sticky-cta-btn" onclick="document.getElementById('jgzAtcBtn').click()">Add to Bag</button>
</div>

<script>
(function() {
  var jgzOpts = {};
  {%- for option in product.options_with_values -%}
    jgzOpts[{{ option.position }}] = '{{ option.selected_value | escape }}';
  {%- endfor -%}
  var jgzVariants = {{ product.variants | json }};
  var jgzQtyVal = 1;
  var jgzCurrentIdx = 0;

  function jgzUpdateVariant() {
    var match = null;
    for (var i = 0; i < jgzVariants.length; i++) {
      var v = jgzVariants[i];
      var keys = Object.keys(jgzOpts);
      var isMatch = true;
      for (var k = 0; k < keys.length; k++) {
        if (v['option' + keys[k]] !== jgzOpts[keys[k]]) { isMatch = false; break; }
      }
      if (isMatch) { match = v; break; }
    }
    if (!match) return;

    var vidEl = document.getElementById('jgzVariantId');
    if (vidEl) vidEl.value = match.id;

    var priceEl = document.getElementById('jgzPrice');
    if (priceEl) {
      var formatted = 'Rs. ' + (match.price / 100).toFixed(0).replace(/\B(?=(\d{3})+(?!\d))/g, ',');
      priceEl.textContent = formatted;
    }

    var atcBtn = document.getElementById('jgzAtcBtn');
    if (atcBtn) atcBtn.textContent = match.available ? 'Add to Bag' : 'Sold Out';

    var buyBtn = document.getElementById('jgzBuyNow');
    if (buyBtn) buyBtn.setAttribute('data-variant', match.id);
  }

  window.jgzThumb = function(el, src) {
    document.querySelectorAll('.jgz-gallery-thumb').forEach(function(t){ t.classList.remove('active'); });
    el.classList.add('active');
    jgzCurrentIdx = parseInt(el.dataset.idx || 0);
    var main = document.getElementById('jgzMainImg');
    if (main) main.src = src;
  };

  window.jgzNavImg = function(dir) {
    var thumbs = document.querySelectorAll('.jgz-gallery-thumb');
    if (!thumbs.length) return;
    jgzCurrentIdx = (jgzCurrentIdx + dir + thumbs.length) % thumbs.length;
    thumbs[jgzCurrentIdx].click();
  };

  window.jgzQty = function(d) {
    jgzQtyVal = Math.max(1, jgzQtyVal + d);
    var dispEl = document.getElementById('jgzQtyDisplay');
    var hidEl = document.getElementById('jgzQtyHidden');
    if (dispEl) dispEl.textContent = jgzQtyVal;
    if (hidEl) hidEl.value = jgzQtyVal;
  };

  window.jgzSelectColor = function(el, pos, val) {
    el.parentElement.querySelectorAll('.jgz-color-opt').forEach(function(c){ c.classList.remove('active'); });
    el.classList.add('active');
    var nameEl = document.getElementById('jgzColorName');
    if (nameEl) nameEl.textContent = val;
    jgzOpts[pos] = val;
    jgzUpdateVariant();
  };

  window.jgzSelectSize = function(el, pos, val) {
    if (el.classList.contains('soldout')) return;
    el.parentElement.querySelectorAll('.jgz-size-opt').forEach(function(s){ s.classList.remove('active'); });
    el.classList.add('active');
    jgzOpts[pos] = val;
    jgzUpdateVariant();
  };

  window.jgzToggle = function(btn) {
    btn.parentElement.classList.toggle('open');
  };

  window.jgzBuyNow = function() {
    var variantId = document.getElementById('jgzVariantId').value;
    var qty = jgzQtyVal;
    window.location.href = '/cart/' + variantId + ':' + qty + '?checkout';
  };

  document.addEventListener('DOMContentLoaded', function() {
    var form = document.getElementById('jgz-product-form');
    if (form) {
      form.addEventListener('submit', function() {
        var btn = document.getElementById('jgzAtcBtn');
        if (!btn) return;
        setTimeout(function() {
          btn.textContent = '✓ Added to Bag!';
          btn.classList.add('added');
          setTimeout(function() {
            btn.textContent = 'Add to Bag';
            btn.classList.remove('added');
          }, 2000);
        }, 300);
      });
    }
  });
})();
</script>

</div>

{% schema %}
{
  "name": "JIGERZ Product Detail",
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "text",
      "id": "fabric_care",
      "label": "Fabric & Care info"
    },
    {
      "type": "text",
      "id": "shipping_returns",
      "label": "Shipping & Returns info"
    },
    {
      "type": "text",
      "id": "size_fit",
      "label": "Size & Fit info"
    }
  ],
  "presets": [{ "name": "JIGERZ Product Detail" }]
}
{% endschema %}
