<style>
  .jgz-marquee-section {
    background: #141414;
    border-top: 1px solid rgba(255,255,255,0.08);
    border-bottom: 1px solid rgba(255,255,255,0.08);
    padding: 18px 0;
    overflow: hidden;
  }

  .jgz-marquee-track {
    display: flex;
    white-space: nowrap;
    animation: jgzMarquee 25s linear infinite;
  }

  .jgz-marquee-track__inner {
    display: flex;
    align-items: center;
    gap: 0;
    flex-shrink: 0;
  }

  .jgz-marquee-item {
    font-family: 'Barlow', system-ui, sans-serif;
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: #f5f4f0;
    opacity: 0.7;
    padding: 0 32px;
  }

  .jgz-marquee-item span {
    color: #b8975a;
  }

  @keyframes jgzMarquee {
    0%   { transform: translateX(0); }
    100% { transform: translateX(-50%); }
  }
</style>

<div class="jgz-marquee-section">
  <div class="jgz-marquee-track">
    {%- assign items = section.settings.marquee_text | split: '·' -%}
    <div class="jgz-marquee-track__inner" aria-hidden="true">
      {%- for item in items -%}
        <span class="jgz-marquee-item">{{ item | strip }} <span>✦</span></span>
      {%- endfor -%}
    </div>
    <div class="jgz-marquee-track__inner" aria-hidden="true">
      {%- for item in items -%}
        <span class="jgz-marquee-item">{{ item | strip }} <span>✦</span></span>
      {%- endfor -%}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "JIGERZ Marquee",
  "settings": [
    {
      "type": "text",
      "id": "marquee_text",
      "label": "Marquee items (separated by ·)",
      "default": "Premium Imported Fabric · Summer 2026 · Free Delivery 2500+ · Cash On Delivery · JIGERZ — Not Just A Brand · Limited Summer Sale · New Arrivals Weekly"
    }
  ],
  "presets": [{ "name": "JIGERZ Marquee" }]
}
{% endschema %}
