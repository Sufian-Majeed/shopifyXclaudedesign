{{ 'base.css' | asset_url | stylesheet_tag: preload: true }}
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;0,700;1,300;1,400&family=Barlow:wght@300;400;500;600&display=swap" rel="stylesheet">
{{ 'jigerz-theme.css' | asset_url | stylesheet_tag }}
<style>
  :root {
    --jgz-black: #0a0a0a;
    --jgz-off-white: #f5f4f0;
    --jgz-gold: #b8975a;
    --jgz-card-bg: #141414;
    --jgz-border: rgba(255,255,255,0.08);
    --jgz-sale-red: #e85d04;
    --jgz-cod-green: #4caf50;
    --jgz-heading: 'Cormorant Garamond', Georgia, serif;
    --jgz-body: 'Barlow', system-ui, sans-serif;
    --jgz-px: 60px;
    --jgz-px-m: 20px;
  }

  /* ══════════════════════════════════════
     JIGERZ HEADER — dark bg, blur, border
     ══════════════════════════════════════ */
  header-component,
  #header-component,
  .header__row,
  .header__row--top,
  .header__underlay,
  .header__underlay-closed,
  .header-section {
    background: rgba(10,10,10,0.97) !important;
    background-color: rgba(10,10,10,0.97) !important;
    color: #f5f4f0 !important;
  }
  header-component {
    backdrop-filter: blur(12px) !important;
    -webkit-backdrop-filter: blur(12px) !important;
    border-bottom: 1px solid rgba(255,255,255,0.08) !important;
  }

  /* 3-column layout: nav | LOGO CENTER | actions */
  @media screen and (min-width: 750px) {
    .header__row--top .header__columns {
      display: flex !important;
      justify-content: space-between !important;
      align-items: center !important;
      padding: 0 48px !important;
      height: 72px !important;
      position: relative !important;
      gap: 0 !important;
    }
    /* Logo: absolute center */
    .header__row--top .header-logo,
    .header__row--top header-logo-block {
      position: absolute !important;
      left: 50% !important;
      transform: translateX(-50%) !important;
      z-index: 2 !important;
    }
    /* Left col (menu) */
    .header__column--left { order: 1 !important; flex: 1 !important; }
    /* Right col (actions) */
    .header__column--right { order: 3 !important; flex: 1 !important; justify-content: flex-end !important; }
    /* Center col (if exists) */
    .header__column--center { order: 2 !important; }
  }

  /* Nav links */
  .header__row a,
  .menu-list__link,
  .header__row button,
  .header-menu a {
    color: #f5f4f0 !important;
    font-family: 'Barlow', system-ui, sans-serif !important;
    font-size: 11px !important;
    letter-spacing: 0.13em !important;
    text-transform: uppercase !important;
    opacity: 0.7 !important;
    transition: opacity 0.2s !important;
    text-decoration: none !important;
  }
  .header__row a:hover, .menu-list__link:hover, .header__row button:hover { opacity: 1 !important; }

  /* Logo image white */
  .header__row img { filter: brightness(0) invert(1) !important; }
  /* Icons */
  .header__row svg, .header__row .icon { color: #f5f4f0 !important; fill: #f5f4f0 !important; stroke: #f5f4f0 !important; }

  /* Cart/Bag button — gold */
  header-actions a[href*="cart"],
  .header__row a[href*="cart"],
  header-actions button[aria-label*="art" i],
  .cart-notification-button {
    background: #b8975a !important;
    color: #0a0a0a !important;
    padding: 8px 18px !important;
    font-weight: 600 !important;
    opacity: 1 !important;
  }
  header-actions a[href*="cart"] svg,
  header-actions button[aria-label*="art" i] svg { fill: #0a0a0a !important; stroke: #0a0a0a !important; color: #0a0a0a !important; }

  /* Announcement bar (header-announcements section) */
  .announcement-bar, .header-announcements, aside.announcement-bar { background: #b8975a !important; border-bottom: none !important; }
  .announcement-bar *, .header-announcements * { color: #0a0a0a !important; font-family: 'Barlow', system-ui, sans-serif !important; font-size: 11px !important; font-weight: 600 !important; letter-spacing: 0.15em !important; text-transform: uppercase !important; }

  /* ── JIGERZ FOOTER OVERRIDE ── */
  footer, .shopify-section--footer, #footer-group, #footer-group .shopify-section { background: #060606 !important; }

  /* ── GLOBAL DARK BASE ── */
  body { background: #0a0a0a !important; color: #f5f4f0 !important; font-family: 'Barlow', system-ui, sans-serif !important; }

  /* ── HIDE FOOTER UTILITIES (duplicate bottom bar) ── */
  .footer-utilities, .shopify-section:has(.footer-utilities), .shopify-section .utilities { display: none !important; }
</style>
