{{ 'overflow-list.css' | asset_url | preload_tag: as: 'style' }}
{{ 'base.css' | asset_url | stylesheet_tag: preload: true }}
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;0,700;1,300;1,400&family=Barlow:wght@300;400;500;600&display=swap" rel="stylesheet">
{{ 'jigerz-theme.css' | asset_url | stylesheet_tag }}
<style>
  :root {
    --jgz-black: #0a0a0a;
    --jgz-off-white: #f5f4f0;
    --jgz-gold: #b8975a;
    --jgz-card-bg: #141414;
    --jgz-border: rgba(255,255,255,0.08);
    --jgz-sale-red: #e85d04;
    --jgz-cod-green: #4caf50;
    --jgz-heading: 'Cormorant Garamond', Georgia, serif;
    --jgz-body: 'Barlow', system-ui, sans-serif;
    --jgz-px: 60px;
    --jgz-px-m: 20px;
  }

  /* ── JIGERZ HEADER OVERRIDES ── */
  #header-group,
  #header-component,
  header-component,
  .header__row,
  .header__row--top,
  .color-scheme-1,
  [class*="color-scheme"] {
    background: rgba(10,10,10,0.97) !important;
    background-color: rgba(10,10,10,0.97) !important;
    border-bottom-color: rgba(255,255,255,0.08) !important;
    color: #f5f4f0 !important;
  }
  header-component {
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border-bottom: 1px solid rgba(255,255,255,0.08) !important;
  }
  /* Nav links */
  .header__row a,
  .menu-list__link,
  .header__row button,
  .header__row [role="button"],
  .header-menu a {
    color: #f5f4f0 !important;
    font-family: 'Barlow', system-ui, sans-serif !important;
    font-size: 11px !important;
    letter-spacing: 0.12em !important;
    text-transform: uppercase !important;
    opacity: 0.7;
    transition: opacity 0.2s;
  }
  .header__row a:hover,
  .menu-list__link:hover,
  .header__row button:hover { opacity: 1 !important; }
  /* Logo */
  .header__row img { filter: brightness(0) invert(1); }
  /* Icons (search, cart, account) */
  .header__row svg, .header__row .icon { color: #f5f4f0 !important; fill: #f5f4f0 !important; stroke: #f5f4f0 !important; }
  /* Announcement bar */
  .header-announcements, .announcement-bar { background: #0a0a0a !important; color: #f5f4f0 !important; border-bottom: 1px solid rgba(255,255,255,0.08) !important; }
  .header-announcements a, .announcement-bar a { color: #b8975a !important; }

  /* ── JIGERZ FOOTER OVERRIDE ── */
  footer, .shopify-section--footer, #footer-group { background: #060606 !important; }
</style>
